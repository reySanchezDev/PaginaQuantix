---
import Container from "../ui/Container.astro";
import Badge from "../ui/Badge.astro";
import Button from "../ui/Button.astro";
import { communityTools } from "../../data/communityTools";

interface Props {
  id: string;
  lang: "es" | "en";
}

const { id, lang } = Astro.props;

import esTranslations from "../../i18n/es.json";
import enTranslations from "../../i18n/en.json";

const t = lang === "es" ? esTranslations : enTranslations;
---

<section id={id} class="tools-section">
  <div class="section-bg-overlay"></div>

  <Container>
    <div class="section-header">
      <h1 class="section-title">{t["community.title"]}</h1>
      <p class="section-desc">{t["community.description"]}</p>
    </div>

    <div class="tools-grid">
      {
        communityTools.map((tool) => (
          <div class="tool-card">
            <div class="tool-header">
              <div class="tool-icon-wrapper">
                {tool.icon === "camera" && (
                    <svg
                      class="tool-icon"
                      width="28"
                      height="28"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    >
                      <path d="M14.5 4h-5L7 7H4a2 2 0 0 0-2 2v9a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-3l-2.5-3z" />
                      <circle cx="12" cy="13" r="3" />
                    </svg>
                )}
              </div>
              <div class="tool-badge-wrap">
                <Badge variant="accent" class="version-badge">v{tool.version}</Badge>
              </div>
            </div>

            <div class="tool-body">
              <div class="tool-meta">
                <span class="tool-type">{tool.type}</span>
              </div>
              <h2 class="tool-title">{tool.title}</h2>
              <p class="tool-desc">{tool.description[lang]}</p>

              <ul class="tool-features">
                {tool.features[lang].map((feature) => (
                  <li>
                    <svg
                      class="check-icon"
                      width="16"
                      height="16"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="3"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    >
                      <polyline points="20 6 9 17 4 12" />
                    </svg>
                    <span>{feature}</span>
                  </li>
                ))}
              </ul>
              
              <div class="tags-container">
                {tool.tags.map(tag => (
                   <span class="tool-tag">{tag}</span>
                ))}
              </div>
            </div>

            <div class="tool-footer">
              <Button
                href={tool.downloadUrl}
                target="_blank"
                variant="primary"
                class:list={["download-btn w-full"]}
                data-tool-id={tool.id}
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="18"
                  height="18"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" />
                  <polyline points="7 10 12 15 17 10" />
                  <line x1="12" y1="15" x2="12" y2="3" />
                </svg>
                {t["community.download"]}
              </Button>
            </div>
          </div>
        ))
      }
    </div>
  </Container>
</section>

<style>
  .tools-section {
    position: relative;
    padding: var(--space-32) 0 var(--space-40);
    background-color: var(--bg);
    min-height: 80vh;
  }

  .section-bg-overlay {
    position: absolute;
    inset: 0;
    background-image: 
      radial-gradient(circle at 15% 50%, rgba(var(--primary-rgb), 0.05), transparent 25%),
      radial-gradient(circle at 85% 30%, rgba(var(--primary-rgb), 0.05), transparent 25%);
    pointer-events: none;
  }

  .section-header {
    text-align: center;
    max-width: 800px;
    margin: 0 auto var(--space-20);
    position: relative;
    z-index: 10;
  }

  .section-title {
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 800;
    margin-bottom: var(--space-6);
    letter-spacing: -0.03em;
    background: linear-gradient(135deg, var(--primary) 0%, var(--accent) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .section-desc {
    color: var(--text-muted);
    font-size: var(--text-lg);
    line-height: 1.6;
    max-width: 600px;
    margin: 0 auto;
  }

  .tools-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-10);
    position: relative;
    z-index: 10;
    justify-content: center;
  }

  @media (min-width: 768px) {
    .tools-grid {
      grid-template-columns: repeat(auto-fit, minmax(450px, 600px));
      margin: 0 auto;
    }
    
    /* Si solo hay una herramienta, permitir que sea más ancha para mostrar bien la info */
    .tools-grid:has(> :only-child) {
      grid-template-columns: minmax(450px, 900px);
    }
  }

  .tool-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-xl);
    padding: var(--space-6) var(--space-6) var(--space-8);
    display: flex;
    flex-direction: column;
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    box-shadow: var(--shadow-sm);
    height: 100%;
  }

  .tool-card:hover {
    transform: translateY(-8px);
    box-shadow: var(--shadow-xl);
    border-color: var(--primary-soft);
  }

  .tool-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: var(--space-6);
  }

  .tool-icon-wrapper {
    width: 64px;
    height: 64px;
    border-radius: var(--radius-lg);
    background: linear-gradient(135deg, var(--surface-2) 0%, var(--surface) 100%);
    border: 1px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--primary);
    box-shadow: 0 4px 10px rgba(0,0,0,0.03);
    transition: transform 0.3s ease;
  }

  .tool-card:hover .tool-icon-wrapper {
    transform: scale(1.05) rotate(-3deg);
    color: var(--accent);
    border-color: var(--primary-soft);
  }

  .tool-body {
    flex-grow: 1;
    display: flex;
    flex-direction: column;
  }

  .tool-meta {
    margin-bottom: var(--space-2);
  }

  .tool-type {
    font-size: var(--text-xs);
    font-weight: 600;
    color: var(--text-subtle);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .tool-title {
    font-size: var(--text-2xl);
    margin-bottom: var(--space-3);
    color: var(--text);
  }

  .tool-desc {
    color: var(--text-muted);
    font-size: var(--text-sm);
    line-height: 1.6;
    margin-bottom: var(--space-6);
  }

  .tool-features {
    list-style: none;
    padding: 0;
    margin: 0 0 var(--space-10) 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4);
  }

  @media (min-width: 768px) {
    .tool-card:only-child .tool-features {
      grid-template-columns: repeat(2, 1fr);
      column-gap: var(--space-8);
    }
  }

  .tool-features li {
    display: flex;
    align-items: flex-start;
    gap: var(--space-3);
    font-size: var(--text-sm);
    color: var(--text);
  }

  .check-icon {
    color: var(--primary);
    flex-shrink: 0;
    background: var(--primary-soft);
    width: 20px;
    height: 20px;
    padding: 3px;
    border-radius: 4px;
    margin-top: 2px;
  }

  .tags-container {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin-bottom: var(--space-8);
    margin-top: auto;
  }

  .tool-tag {
    font-size: 11px;
    background: var(--surface-2);
    color: var(--text-muted);
    padding: 4px 10px;
    border-radius: 99px;
    font-weight: 500;
    border: 1px solid transparent;
  }

  .tool-card:hover .tool-tag {
    background: var(--primary-soft);
    color: var(--primary);
    border-color: rgba(var(--primary-rgb), 0.1);
  }

  .tool-footer {
    margin-top: auto;
    padding-top: var(--space-6);
    border-top: 1px solid var(--border);
  }

  .w-full {
    width: 100%;
  }

  .download-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    box-shadow: 0 4px 12px rgba(var(--primary-rgb), 0.2);
  }

  .download-btn:hover {
    box-shadow: 0 6px 16px rgba(var(--primary-rgb), 0.3);
  }
</style>

<script>
  import { track } from "../../lib/vercelAnalytics";

  function setupTracking() {
    const downloadButtons = document.querySelectorAll('.download-btn');
    
    downloadButtons.forEach(btn => {
      btn.addEventListener('click', () => {
        const toolId = (btn as HTMLElement).dataset.toolId;
        if (toolId) {
          track('community_download_click', {
            toolId: toolId,
            url: (btn as HTMLAnchorElement).href
          });
        }
      });
    });
  }

  // Initialize tracking
  setupTracking();
  // Support Astro View Transitions
  document.addEventListener('astro:page-load', setupTracking);
</script>
