---
import Container from "../ui/Container.astro";

interface Props {
  id: string;
  title: string;
  description: string;
  lang?: "es" | "en";
}

const inferredLocale = Astro.currentLocale === "es" ? "es" : "en";
const { id, title, description, lang = inferredLocale } = Astro.props;

const t =
  lang === "es"
    ? {
        emailCta: "Enviar correo",
        whatsappCta: "Chatear ahora",
        scheduleLabel: "Horario",
        scheduleValue: "Lun - Vie, 9am - 6pm",
        support: "Soporte 24/7 para emergencias",
      }
    : {
        emailCta: "Send email",
        whatsappCta: "Chat now",
        scheduleLabel: "Schedule",
        scheduleValue: "Mon - Fri, 9am - 6pm",
        support: "24/7 support for emergencies",
      };
---

<section id={id} class="contact-section">
  <div class="bg-glow"></div>

  <Container>
    <div class="section-header">
      <h2 class="section-title">{title}</h2>
      <p class="section-desc">{description}</p>
    </div>

    <div class="contact-grid">
      <a href="mailto:reynaldv12@gmail.com" class="contact-card contact-card--link group">
        <div class="icon-box">
          <svg
            width="26"
            height="26"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <rect width="20" height="16" x="2" y="4" rx="2"></rect>
            <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path>
          </svg>
        </div>
        <div class="card-content">
          <span class="label">Email</span>
          <span class="value">reynaldv12@gmail.com</span>
          <span class="cta">{t.emailCta} &rarr;</span>
        </div>
      </a>

      <a
        href="https://wa.me/50585213462"
        target="_blank"
        rel="noopener noreferrer"
        class="contact-card contact-card--link group"
      >
        <div class="icon-box">
          <svg
            width="26"
            height="26"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path d="M3 21l1.65-3.8a9 9 0 1 1 3.4 2.9L3 21"></path>
            <path d="M9 10a.5.5 0 0 0 1 0V9a.5.5 0 0 0-1 0v1a5 5 0 0 0 5 5h1a.5.5 0 0 0 0-1h-1a.5.5 0 0 0 0 1"></path>
          </svg>
        </div>
        <div class="card-content">
          <span class="label">WhatsApp</span>
          <span class="value">+505 8521 3462</span>
          <span class="cta">{t.whatsappCta} &rarr;</span>
        </div>
      </a>

      <div class="contact-card contact-card--static">
        <div class="icon-box">
          <svg
            width="26"
            height="26"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <circle cx="12" cy="12" r="10"></circle>
            <polyline points="12 6 12 12 16 14"></polyline>
          </svg>
        </div>
        <div class="card-content">
          <span class="label">{t.scheduleLabel}</span>
          <span class="value">{t.scheduleValue}</span>
          <span class="cta text-muted">{t.support}</span>
        </div>
      </div>
    </div>
  </Container>
</section>

<style>
  .contact-section {
    padding: clamp(4.5rem, 9vw, var(--space-24)) 0;
    background-color: #020617;
    color: #fff;
    position: relative;
    overflow: hidden;
  }

  .bg-glow {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 100%;
    height: 100%;
    background: radial-gradient(
      circle at center,
      rgba(37, 99, 235, 0.15) 0%,
      transparent 60%
    );
    pointer-events: none;
    z-index: 1;
  }

  .section-header {
    position: relative;
    z-index: 10;
    text-align: center;
    max-width: 700px;
    margin: 0 auto clamp(var(--space-8), 6vw, var(--space-16));
  }

  .section-title {
    font-size: clamp(2rem, 5vw, var(--text-4xl));
    font-weight: 800;
    margin-bottom: var(--space-4);
    letter-spacing: -0.02em;
    color: white;
  }

  .section-desc {
    font-size: clamp(1rem, 2.5vw, var(--text-lg));
    color: #94a3b8;
  }

  .contact-grid {
    position: relative;
    z-index: 10;
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(var(--space-4), 4vw, var(--space-6));
    max-width: 1024px;
    margin: 0 auto;
  }

  @media (min-width: 768px) {
    .contact-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .contact-card {
    display: grid;
    grid-template-columns: auto 1fr;
    align-items: start;
    gap: clamp(var(--space-4), 3vw, var(--space-5));
    padding: clamp(1.15rem, 3vw, 1.5rem);
    background:
      linear-gradient(
        180deg,
        rgba(15, 23, 42, 0.88) 0%,
        rgba(15, 23, 42, 0.74) 100%
      );
    border: 1px solid rgba(148, 163, 184, 0.14);
    border-radius: 1.4rem;
    backdrop-filter: blur(10px);
    transition:
      transform 0.35s cubic-bezier(0.16, 1, 0.3, 1),
      border-color 0.35s ease,
      background-color 0.35s ease,
      box-shadow 0.35s ease;
    text-decoration: none;
    color: inherit;
  }

  .contact-card--link:hover {
    transform: translateY(-4px);
    background:
      linear-gradient(
        180deg,
        rgba(15, 23, 42, 0.94) 0%,
        rgba(15, 23, 42, 0.82) 100%
      );
    border-color: rgba(96, 165, 250, 0.28);
    box-shadow: 0 16px 36px -16px rgba(2, 6, 23, 0.72);
  }

  .contact-card--static {
    cursor: default;
  }

  .icon-box {
    width: 3rem;
    height: 3rem;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(37, 99, 235, 0.08);
    color: #60a5fa;
    border: 1px solid rgba(96, 165, 250, 0.18);
    border-radius: 1rem;
    transition:
      transform 0.28s ease,
      background-color 0.28s ease,
      color 0.28s ease,
      border-color 0.28s ease;
  }

  .contact-card--link:hover .icon-box {
    background: rgba(37, 99, 235, 0.16);
    color: #bfdbfe;
    border-color: rgba(147, 197, 253, 0.32);
    transform: translateY(-1px);
  }

  .card-content {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    min-width: 0;
  }

  .label {
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    font-weight: 700;
    color: #7c8aa5;
  }

  .value {
    font-size: clamp(1.02rem, 2vw, 1.22rem);
    font-weight: 650;
    color: white;
    line-height: 1.25;
    text-wrap: balance;
  }

  .cta {
    margin-top: 0.45rem;
    font-size: 0.92rem;
    font-weight: 600;
    color: #93c5fd;
    display: inline-flex;
    align-items: center;
    justify-content: flex-start;
    gap: 0.3rem;
    transition:
      gap 0.2s ease,
      color 0.2s ease;
  }

  .contact-card--link:hover .cta {
    gap: 0.5rem;
    color: #dbeafe;
  }

  .text-muted {
    color: #72829c;
  }

  @media (max-width: 767px) {
    .section-header {
      text-align: left;
      margin-bottom: var(--space-8);
    }

    .contact-grid {
      gap: var(--space-4);
    }

    .contact-card {
      gap: 0.95rem;
      padding: 1.15rem 1rem;
      border-radius: 1.25rem;
    }

    .icon-box {
      width: 2.85rem;
      height: 2.85rem;
    }

    .card-content {
      width: 100%;
    }
  }
</style>
