---
import Container from "../ui/Container.astro";

interface Props {
  id: string;
  title: string;
  description: string;
  lang?: "es" | "en";
}

const inferredLocale = Astro.currentLocale === "es" ? "es" : "en";
const { id, title, description, lang = inferredLocale } = Astro.props;

const featuresByLocale = {
  es: [
    {
      title: "Software a Medida",
      desc: "Creamos ecosistemas digitales escalables y de alto rendimiento adaptados a tu modelo de negocio.",
      image: "/images/funcion1.jpg",
    },
    {
      title: "Automatizacion RPA",
      desc: "Optimizamos tus procesos operativos eliminando tareas repetitivas con bots de inteligencia avanzada.",
      image: "/images/funcion2.jpg",
    },
    {
      title: "Infraestructura Cloud",
      desc: "Migracion y gestion de entornos en la nube con maxima seguridad y disponibilidad 24/7.",
      image: "/images/funcion3.jpg",
    },
    {
      title: "Consultoria Tech",
      desc: "Transformamos retos complejos en soluciones tecnicas eficientes mediante arquitectura de software proactiva.",
      image: "/images/funcion4.jpg",
    },
  ],
  en: [
    {
      title: "Custom Software",
      desc: "We build scalable high-performance digital ecosystems tailored to your business model.",
      image: "/images/funcion1.jpg",
    },
    {
      title: "RPA Automation",
      desc: "We optimize operations by removing repetitive work with advanced automation bots.",
      image: "/images/funcion2.jpg",
    },
    {
      title: "Cloud Infrastructure",
      desc: "Cloud migration and environment management with maximum security and 24/7 availability.",
      image: "/images/funcion3.jpg",
    },
    {
      title: "Tech Consulting",
      desc: "We turn complex challenges into efficient technical solutions through proactive architecture.",
      image: "/images/funcion4.jpg",
    },
  ],
};

const features = featuresByLocale[lang];
---

<section id={id} class="features-section">
  <div class="background-decor">
    <div class="dot-matrix"></div>
    <div class="radial-glow"></div>
  </div>

  <Container>
    <div class="section-header">
      <h2 class="section-title">{title}</h2>
      <p class="section-desc">{description}</p>
    </div>

    <div class="features-grid">
      {
        features.map((feature) => (
          <div class="feature-card">
            <div class="card-bg" style={`background-image: url(${feature.image})`}></div>
            <div class="card-overlay"></div>
            <div class="card-border"></div>

            <div class="card-content">
              <h3 class="feature-title">{feature.title}</h3>
              <p class="feature-desc">{feature.desc}</p>
            </div>
          </div>
        ))
      }
    </div>
  </Container>

  <div class="section-separator"></div>
</section>

<style>
  .features-section {
    position: relative;
    padding: var(--space-32) 0 var(--space-40);
    background-color: #f8fafc;
    transition: background-color 0.3s ease;
    overflow: hidden;
  }

  .background-decor {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
  }

  .dot-matrix {
    position: absolute;
    inset: 0;
    background-image: radial-gradient(rgba(var(--primary-rgb), 0.09) 1px, transparent 1px);
    background-size: 32px 32px;
    opacity: 0.5;
  }

  .radial-glow {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 100%;
    height: 100%;
    background: radial-gradient(circle at center, var(--primary-soft) 0%, transparent 70%);
    opacity: 0.1;
  }

  .section-separator {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 1px;
    background: linear-gradient(to right, transparent, var(--border), transparent);
  }

  .section-header {
    position: relative;
    z-index: 1;
    text-align: center;
    max-width: 800px;
    margin: 0 auto var(--space-16);
  }

  .section-title {
    font-size: clamp(2.5rem, 5vw, 3.5rem);
    font-weight: 800;
    margin-bottom: var(--space-4);
    letter-spacing: -0.03em;
    background: linear-gradient(135deg, var(--primary) 0%, var(--accent) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .features-grid {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-8);
  }

  @media (min-width: 640px) {
    .features-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .features-grid {
      grid-template-columns: repeat(4, 1fr);
      gap: var(--space-6);
    }
  }

  .feature-card {
    position: relative;
    height: 480px;
    border-radius: var(--radius-xl);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: var(--space-8);
    transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1);
    background: color-mix(in srgb, var(--surface) 88%, var(--primary-soft));
  }

  @media (max-width: 639px) {
    .feature-card {
      height: 380px;
      padding: var(--space-6);
    }

    .features-section {
      padding: var(--space-16) 0;
    }
  }

  .card-border {
    position: absolute;
    inset: 0;
    border: 1px solid rgba(255, 255, 255, 0.22);
    border-radius: var(--radius-xl);
    pointer-events: none;
    z-index: 4;
    transition: all 0.5s ease;
  }

  .feature-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 20px 40px rgba(var(--primary-rgb), 0.18);
  }

  .feature-card:hover .card-border {
    border-color: var(--primary);
    box-shadow: inset 0 0 15px rgba(var(--primary-rgb), 0.2);
  }

  .card-bg {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-size: cover;
    background-position: center;
    transition: transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
    z-index: 1;
  }

  .card-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(22, 50, 74, 0.82) 0%,
      rgba(22, 50, 74, 0.34) 50%,
      transparent 100%
    );
    z-index: 2;
    transition: background 0.5s ease;
  }

  .feature-card:hover .card-bg {
    transform: scale(1.15);
  }

  .feature-card:hover .card-overlay {
    background: linear-gradient(
      to top,
      rgba(22, 50, 74, 0.9) 0%,
      rgba(31, 164, 162, 0.24) 60%,
      transparent 100%
    );
  }

  .card-content {
    position: relative;
    z-index: 3;
    transition: transform 0.4s ease;
  }

  .feature-title {
    font-size: var(--text-xl);
    font-weight: 700;
    color: white;
    margin-bottom: var(--space-2);
    text-shadow: 0 2px 4px rgba(22, 50, 74, 0.24);
  }

  .feature-desc {
    font-size: var(--text-base);
    color: rgba(255, 255, 255, 0.85);
    line-height: 1.6;
    opacity: 0;
    transform: translateY(20px);
    transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1);
    max-height: 0;
    overflow: hidden;
  }

  .feature-card:hover .feature-desc {
    opacity: 1;
    transform: translateY(0);
    max-height: 180px;
    margin-top: var(--space-3);
  }
</style>
