---
import Container from "../ui/Container.astro";
import Button from "../ui/Button.astro";
import { products } from "../../data/products";

interface Props {
  id: string;
  title: string;
  description: string;
  lang: "es" | "en";
}

const { id, title, description, lang } = Astro.props;
---

<section id={id} class="products-section">
  <div class="section-bg-overlay"></div>

  <Container>
    <div class="section-header">
      <h2 class="section-title">{title}</h2>
      <p class="section-desc">{description}</p>
    </div>

    <div class="products-list">
      {
        products.map((product) => (
          <div class="product-card">
            <div class="product-thumb" style={`background: ${product.gradient}`}>
              <div class="thumb-overlay"></div>
            </div>

            <div class="product-info">
              <div class="info-content">
                <div class="product-meta">
                  <span class="product-status">{product.status[lang]}</span>
                </div>
                <h3 class="product-title">{product.title[lang]}</h3>
                <p class="product-desc">{product.description[lang]}</p>
                <p class="product-availability">{product.availabilityNote[lang]}</p>

                <ul class="product-features">
                  {product.features[lang].map((feature) => (
                    <li>
                      <svg
                        class="check-icon"
                        width="16"
                        height="16"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="3"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        aria-hidden="true"
                      >
                        <polyline points="20 6 9 17 4 12" />
                      </svg>
                      <span>{feature}</span>
                    </li>
                  ))}
                </ul>
              </div>

              <div class="product-actions">
                <Button
                  href={product.href[lang]}
                  target={product.target}
                  variant="glow"
                  class="w-full"
                >
                  {lang === "es" ? "Ver más" : "Learn more"}
                </Button>
              </div>
            </div>
          </div>
        ))
      }
    </div>
  </Container>
</section>

<style>
  .products-section {
    position: relative;
    padding: clamp(5rem, 9vw, var(--space-32)) 0 clamp(5.5rem, 10vw, var(--space-40));
    background: linear-gradient(180deg, color-mix(in srgb, var(--primary-soft) 36%, var(--bg)) 0%, var(--bg) 100%);
    overflow: hidden;
  }

  .section-bg-overlay {
    position: absolute;
    inset: 0;
    background-image:
      radial-gradient(rgba(var(--primary-rgb), 0.08) 1px, transparent 1px),
      radial-gradient(circle at 12% 18%, rgba(var(--primary-rgb), 0.1), transparent 24%),
      radial-gradient(circle at 88% 16%, rgba(var(--accent-rgb), 0.1), transparent 22%);
    background-size: 48px 48px, auto, auto;
    opacity: 0.55;
    pointer-events: none;
  }

  .section-header {
    position: relative;
    z-index: 20;
    text-align: center;
    max-width: 800px;
    margin: 0 auto clamp(var(--space-10), 7vw, var(--space-20));
  }

  .section-title {
    font-size: clamp(2rem, 4vw, 2.75rem);
    font-weight: 800;
    line-height: 1.1;
    margin-bottom: var(--space-4);
    background: linear-gradient(135deg, var(--primary) 0%, var(--accent) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    letter-spacing: -0.02em;
  }

  .section-desc {
    color: var(--text-muted);
    font-size: clamp(1rem, 2.4vw, var(--text-lg));
    max-width: 600px;
    margin: 0 auto;
    line-height: 1.6;
  }

  .products-list {
    position: relative;
    z-index: 10;
    display: grid;
    grid-template-columns: 1fr;
    align-items: stretch;
    gap: clamp(var(--space-5), 4vw, var(--space-8));
    max-width: 1200px;
    margin: 0 auto;
  }

  @media (min-width: 1024px) {
    .products-list {
      grid-template-columns: repeat(2, 1fr);
      grid-auto-rows: 1fr;
      gap: var(--space-12);
    }
  }

  .product-card {
    position: relative;
    display: grid;
    grid-template-rows: minmax(10rem, 12.5rem) 1fr;
    background:
      linear-gradient(180deg, color-mix(in srgb, var(--surface) 96%, white 4%), color-mix(in srgb, var(--surface-2) 92%, transparent));
    border: 1px solid color-mix(in srgb, var(--primary) 12%, var(--border));
    border-radius: 24px;
    overflow: hidden;
    transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1);
    box-shadow: 0 18px 36px rgba(23, 50, 74, 0.1);
    min-height: 28rem;
    height: 100%;
    max-width: 36rem;
    margin: 0 auto;
  }

  .product-card:hover {
    transform: translateY(-10px) scale(1.01);
    box-shadow:
      0 28px 48px rgba(23, 50, 74, 0.14),
      0 0 0 1px color-mix(in srgb, var(--accent) 16%, transparent);
    border-color: color-mix(in srgb, var(--primary) 24%, var(--border));
  }

  .product-thumb {
    position: relative;
    width: 100%;
    min-height: clamp(10rem, 28vw, 12.5rem);
    overflow: hidden;
    z-index: 0;
    border-bottom: 1px solid color-mix(in srgb, var(--primary) 10%, var(--border));
  }

  .thumb-overlay {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at 18% 22%, rgba(255, 255, 255, 0.74), transparent 26%),
      linear-gradient(135deg, rgba(255, 255, 255, 0.42), rgba(255, 255, 255, 0.08)),
      linear-gradient(180deg, rgba(var(--primary-rgb), 0.02), rgba(var(--accent-rgb), 0.14));
    z-index: 1;
  }

  .product-info {
    position: relative;
    z-index: 2;
    padding: clamp(var(--space-5), 4vw, var(--space-8));
    min-height: 17rem;
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    background: transparent;
    color: var(--text);
  }

  @media (min-width: 1024px) {
    .product-info {
      padding: var(--space-10);
    }
  }

  .info-content {
    display: flex;
    flex-direction: column;
    flex: 1 1 auto;
  }

  .product-meta {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    margin-bottom: var(--space-3);
  }

  .product-status {
    display: inline-flex;
    align-items: center;
    min-height: 1.75rem;
    border-radius: 999px;
    padding: 0.35rem 0.75rem;
    background: color-mix(in srgb, var(--primary-soft) 80%, white 20%);
    color: var(--primary);
    border: 1px solid color-mix(in srgb, var(--primary) 14%, var(--border));
    font-size: var(--text-xs);
    font-weight: 800;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .product-title {
    font-size: clamp(1.45rem, 4vw, var(--text-2xl));
    font-weight: 800;
    margin-bottom: var(--space-2);
    letter-spacing: -0.03em;
    color: var(--text);
    line-height: 1.2;
  }

  .product-desc {
    color: var(--text-muted);
    font-size: var(--text-sm);
    line-height: 1.6;
    margin-bottom: var(--space-3);
    font-weight: 400;
  }

  .product-availability {
    color: color-mix(in srgb, var(--text) 82%, var(--text-muted));
    font-size: var(--text-xs);
    line-height: 1.6;
    margin: 0 0 var(--space-5);
    padding: 0.75rem 0.85rem;
    border: 1px solid color-mix(in srgb, var(--primary) 12%, var(--border));
    border-radius: var(--radius-md);
    background: color-mix(in srgb, var(--surface) 88%, var(--primary-soft));
  }

  .product-features {
    list-style: none;
    padding: 0;
    margin: 0 0 var(--space-5) 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .product-features li {
    display: flex;
    align-items: flex-start;
    gap: var(--space-2);
    font-size: var(--text-xs);
    color: color-mix(in srgb, var(--text) 86%, var(--text-muted));
    font-weight: 500;
  }

  .check-icon {
    color: var(--primary);
    flex-shrink: 0;
    background: color-mix(in srgb, var(--primary-soft) 88%, white 12%);
    width: 24px;
    height: 24px;
    padding: 4px;
    border-radius: 6px;
  }

  .product-actions {
    margin-top: auto;
  }

  .w-full {
    width: 100%;
  }

  @media (max-width: 767px) {
    .section-header {
      text-align: left;
      margin-bottom: var(--space-8);
    }

    .section-desc {
      margin: 0;
      max-width: 34rem;
    }

    .product-card {
      display: flex;
      flex-direction: column;
      max-width: none;
      border-radius: 1.4rem;
      min-height: 0;
      height: auto;
    }

    .product-card:hover {
      transform: translateY(-6px);
    }

    .product-info {
      padding: var(--space-5);
    }

    .product-title {
      margin-bottom: 0.35rem;
    }

    .product-desc {
      font-size: 0.95rem;
    }

    .product-features li {
      font-size: 0.76rem;
    }
  }
</style>
