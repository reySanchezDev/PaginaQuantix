---
import Container from "../ui/Container.astro";
import Button from "../ui/Button.astro";
import { products } from "../../data/products";

interface Props {
  id: string;
  title: string;
  description: string;
  lang: "es" | "en";
}

const { id, title, description, lang } = Astro.props;
const constructionNotice =
  lang === "es"
    ? {
        title: "Seccion en mantenimiento",
        message:
          "Esta solucion se encuentra temporalmente en mantenimiento para mejorar rendimiento y estabilidad. Puedes contactarnos para mas informacion.",
        closeLabel: "Entendido",
      }
    : {
        title: "Section under maintenance",
        message:
          "This solution is temporarily under maintenance to improve performance and stability. Please contact us for more information.",
        closeLabel: "Understood",
      };
---

<section id={id} class="products-section">
  <!-- Subtle tech background -->
  <div class="section-bg-overlay"></div>

  <Container>
    <div class="section-header">
      <h2 class="section-title">{title}</h2>
      <p class="section-desc">{description}</p>
    </div>

    <div class="products-list">
      {
        products.map((product) => (
          <div class="product-card">
            <div
              class="product-thumb"
              style={`background: ${product.gradient}`}
            >
              <div class="thumb-overlay" />
              {/* Removed Badges Overlay */}
            </div>

            <div class="product-info">
              <div class="info-content">
                <h3 class="product-title">{product.title[lang]}</h3>
                <p class="product-desc">{product.description[lang]}</p>

                <ul class="product-features">
                  {product.features[lang].map((feature) => (
                    <li>
                      <svg
                        class="check-icon"
                        width="16"
                        height="16"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="3"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      >
                        <polyline points="20 6 9 17 4 12" />
                      </svg>
                      <span>{feature}</span>
                    </li>
                  ))}
                </ul>
              </div>

              <div class="product-actions">
                <Button
                  href={product.href[lang]}
                  target={product.target}
                  variant="glow"
                  class="w-full"
                  data-product-under-construction="true"
                  data-notice-title={constructionNotice.title}
                  data-notice-message={constructionNotice.message}
                  data-notice-close={constructionNotice.closeLabel}
                >
                  {lang === "es" ? "Explorar Solución" : "Explore Solution"}
                </Button>
              </div>
            </div>
          </div>
        ))
      }
    </div>
  </Container>

  <div id="construction-toast" class="construction-toast" aria-hidden="true">
    <div class="construction-toast-card" role="status" aria-live="polite">
      <p id="construction-toast-title" class="construction-toast-title">
        {constructionNotice.title}
      </p>
      <p id="construction-toast-message" class="construction-toast-message">
        {constructionNotice.message}
      </p>
      <button
        id="construction-toast-close"
        type="button"
        class="construction-toast-close"
      >
        {constructionNotice.closeLabel}
      </button>
    </div>
  </div>
</section>

<script>
  function setupConstructionNotice() {
    const toast = document.getElementById("construction-toast");
    const title = document.getElementById("construction-toast-title");
    const message = document.getElementById("construction-toast-message");
    const closeBtn = document.getElementById("construction-toast-close");

    if (!toast || !title || !message || !closeBtn) return;

    let hideTimeout: number | undefined;

    const hideToast = () => {
      toast.classList.remove("open");
      toast.setAttribute("aria-hidden", "true");
    };

    const showToast = (
      nextTitle: string,
      nextMessage: string,
      nextClose: string,
    ) => {
      title.textContent = nextTitle;
      message.textContent = nextMessage;
      closeBtn.textContent = nextClose;
      toast.classList.add("open");
      toast.setAttribute("aria-hidden", "false");

      if (hideTimeout !== undefined) {
        window.clearTimeout(hideTimeout);
      }
      hideTimeout = window.setTimeout(hideToast, 11000);
    };

    if (closeBtn.dataset.noticeBound !== "true") {
      closeBtn.addEventListener("click", hideToast);
      closeBtn.dataset.noticeBound = "true";
    }

    document
      .querySelectorAll('[data-product-under-construction="true"]')
      .forEach((trigger) => {
        if (!(trigger instanceof HTMLElement)) return;
        if (trigger.dataset.noticeBound === "true") return;

        trigger.addEventListener("click", (event) => {
          event.preventDefault();

          const nextTitle =
            trigger.dataset.noticeTitle || title.textContent || "";
          const nextMessage =
            trigger.dataset.noticeMessage || message.textContent || "";
          const nextClose =
            trigger.dataset.noticeClose || closeBtn.textContent || "OK";

          showToast(nextTitle, nextMessage, nextClose);
        });

        trigger.dataset.noticeBound = "true";
      });
  }

  setupConstructionNotice();
  document.addEventListener("astro:page-load", setupConstructionNotice);
</script>

<style>
  .products-section {
    position: relative;
    padding: clamp(5rem, 9vw, var(--space-32)) 0 clamp(5.5rem, 10vw, var(--space-40));
    background-color: var(--bg);
    overflow: hidden;
  }

  .section-bg-overlay {
    position: absolute;
    inset: 0;
    background-image:
      radial-gradient(rgba(var(--primary-rgb), 0.08) 1px, transparent 1px),
      radial-gradient(circle at 12% 18%, rgba(var(--primary-rgb), 0.1), transparent 24%),
      radial-gradient(circle at 88% 16%, rgba(var(--accent-rgb), 0.1), transparent 22%);
    background-size: 48px 48px, auto, auto;
    opacity: 0.55;
    pointer-events: none;
  }

  :global([data-theme="light"]) .products-section {
    background: linear-gradient(180deg, color-mix(in srgb, var(--primary-soft) 36%, var(--bg)) 0%, var(--bg) 100%);
  }

  .section-header {
    position: relative;
    z-index: 20;
    text-align: center;
    max-width: 800px;
    margin: 0 auto clamp(var(--space-10), 7vw, var(--space-20));
  }

  .section-title {
    font-size: clamp(2rem, 4vw, 2.75rem);
    font-weight: 800;
    line-height: 1.1;
    margin-bottom: var(--space-4);
    background: linear-gradient(135deg, var(--primary) 0%, var(--accent) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    letter-spacing: -0.02em;
  }

  .section-desc {
    color: var(--text-muted);
    font-size: clamp(1rem, 2.4vw, var(--text-lg));
    max-width: 600px;
    margin: 0 auto;
    line-height: 1.6;
  }

  /* Grid Layout: Horizontal List (Side-by-Side) */
  .products-list {
    position: relative;
    z-index: 10;
    display: grid;
    grid-template-columns: 1fr;
    align-items: stretch;
    gap: clamp(var(--space-5), 4vw, var(--space-8));
    max-width: 1200px;
    margin: 0 auto;
  }

  @media (min-width: 1024px) {
    .products-list {
      grid-template-columns: repeat(2, 1fr); /* 2 Columns on Desktop */
      grid-auto-rows: 1fr;
      gap: var(--space-12);
    }
  }

  /* Vertical Pro Card for Grid */
  .product-card {
    position: relative;
    display: grid;
    grid-template-rows: minmax(10rem, 12.5rem) 1fr;
    background:
      linear-gradient(180deg, color-mix(in srgb, var(--surface) 96%, white 4%), color-mix(in srgb, var(--surface-2) 92%, transparent));
    border: 1px solid color-mix(in srgb, var(--primary) 12%, var(--border));
    border-radius: 24px;
    overflow: hidden;
    transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1);
    box-shadow: 0 18px 36px rgba(23, 50, 74, 0.1);
    min-height: 28rem;
    height: 100%;
    max-width: 36rem;
    margin: 0 auto;
  }

  :global([data-theme="dark"]) .product-card {
    background:
      linear-gradient(180deg, color-mix(in srgb, var(--surface) 94%, transparent), color-mix(in srgb, var(--surface-2) 88%, transparent));
  }

  .product-card:hover {
    transform: translateY(-10px) scale(1.01);
    box-shadow:
      0 28px 48px rgba(23, 50, 74, 0.14),
      0 0 0 1px color-mix(in srgb, var(--accent) 16%, transparent);
    border-color: color-mix(in srgb, var(--primary) 24%, var(--border));
  }

  .product-thumb {
    position: relative;
    width: 100%;
    min-height: clamp(10rem, 28vw, 12.5rem);
    overflow: hidden;
    z-index: 0;
    border-bottom: 1px solid color-mix(in srgb, var(--primary) 10%, var(--border));
  }

  .thumb-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 1s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .product-card:hover .thumb-img {
    transform: scale(1.1);
  }

  .thumb-overlay {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at 18% 22%, rgba(255, 255, 255, 0.74), transparent 26%),
      linear-gradient(135deg, rgba(255, 255, 255, 0.42), rgba(255, 255, 255, 0.08)),
      linear-gradient(180deg, rgba(var(--primary-rgb), 0.02), rgba(var(--accent-rgb), 0.14));
    z-index: 1;
  }

  .badges-overlay {
    position: absolute;
    top: var(--space-6);
    left: var(--space-6);
    display: flex;
    gap: var(--space-2);
    z-index: 2;
  }

  .compact-badge {
    padding: 6px 16px;
    font-size: 11px;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    background: color-mix(in srgb, var(--surface) 82%, transparent);
    backdrop-filter: blur(8px);
    color: var(--primary);
    border: 1px solid color-mix(in srgb, var(--primary) 16%, var(--border));
    border-radius: 99px;
  }

  .product-info {
    position: relative;
    z-index: 2;
    padding: clamp(var(--space-5), 4vw, var(--space-8));
    min-height: 17rem;
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    background: transparent;
    color: var(--text);
  }

  @media (min-width: 1024px) {
    .product-info {
      padding: var(--space-10);
    }
  }

  .info-content {
    display: flex;
    flex-direction: column;
    flex: 1 1 auto;
  }

  .product-title {
    font-size: clamp(1.45rem, 4vw, var(--text-2xl));
    font-weight: 800;
    margin-bottom: var(--space-2);
    letter-spacing: -0.03em;
    color: var(--text);
    line-height: 1.2;
  }

  .product-desc {
    color: var(--text-muted);
    font-size: var(--text-sm);
    line-height: 1.6;
    margin-bottom: var(--space-5);
    font-weight: 400;
  }

  .product-features {
    list-style: none;
    padding: 0;
    margin: 0 0 var(--space-5) 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .product-features li {
    display: flex;
    align-items: flex-start;
    gap: var(--space-2);
    font-size: var(--text-xs);
    color: color-mix(in srgb, var(--text) 86%, var(--text-muted));
    font-weight: 500;
  }

  .check-icon {
    color: var(--primary);
    flex-shrink: 0;
    background: color-mix(in srgb, var(--primary-soft) 88%, white 12%);
    width: 24px;
    height: 24px;
    padding: 4px;
    border-radius: 6px;
  }

  .product-actions {
    margin-top: auto;
  }

  @media (max-width: 767px) {
    .section-header {
      text-align: left;
      margin-bottom: var(--space-8);
    }

    .section-desc {
      margin: 0;
      max-width: 34rem;
    }

    .product-card {
      display: flex;
      flex-direction: column;
      max-width: none;
      border-radius: 1.4rem;
      min-height: 0;
      height: auto;
    }

    .product-card:hover {
      transform: translateY(-6px);
    }

    .product-info {
      padding: var(--space-5);
    }

    .product-title {
      margin-bottom: 0.35rem;
    }

    .product-desc {
      font-size: 0.95rem;
    }

    .product-features li {
      font-size: 0.76rem;
    }
  }

  .w-full {
    width: 100%;
  }

  .construction-toast {
    position: fixed;
    right: var(--space-4);
    bottom: var(--space-4);
    width: min(420px, calc(100vw - 2rem));
    z-index: 120;
    opacity: 0;
    transform: translateY(16px);
    pointer-events: none;
    transition:
      opacity 0.25s ease,
      transform 0.25s ease;
  }

  .construction-toast.open {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }

  .construction-toast-card {
    background: color-mix(in srgb, var(--surface) 96%, white 4%);
    border: 1px solid color-mix(in srgb, var(--primary) 14%, var(--border));
    border-radius: 16px;
    box-shadow: 0 18px 36px rgba(var(--primary-rgb), 0.16);
    backdrop-filter: blur(10px);
    padding: var(--space-5);
    color: var(--text);
  }

  .construction-toast-title {
    margin: 0 0 var(--space-2) 0;
    font-size: var(--text-base);
    font-weight: 700;
    color: var(--text);
  }

  .construction-toast-message {
    margin: 0;
    font-size: var(--text-sm);
    line-height: 1.55;
    color: color-mix(in srgb, var(--text-muted) 92%, var(--text));
  }

  .construction-toast-close {
    margin-top: var(--space-4);
    border: 1px solid color-mix(in srgb, var(--primary) 14%, var(--border));
    background: color-mix(in srgb, var(--primary-soft) 72%, var(--surface));
    color: var(--primary);
    border-radius: 999px;
    padding: 0.45rem 0.9rem;
    font-size: var(--text-xs);
    font-weight: 600;
    cursor: pointer;
  }

  .construction-toast-close:hover {
    background: color-mix(in srgb, var(--accent-soft) 66%, var(--surface));
  }
</style>
