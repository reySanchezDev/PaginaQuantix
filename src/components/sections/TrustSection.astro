---
import Container from '../ui/Container.astro';

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<section class="trust-section">
  <Container>
    <div class="trust-wrapper">
      <div class="section-header">
        <h2>{title}</h2>
        <p>
          Trust is built through practical engineering habits: clear scope,
          reliable delivery, maintainable systems, and business workflows that
          can be operated with confidence.
        </p>
      </div>

      <div class="principles-grid">
        <article class="principle-card">
          <span class="principle-kicker">Operations</span>
          <h3>Built for real workflows</h3>
          <p>Software decisions should map to inventory, billing, reporting, approvals, and daily execution.</p>
        </article>

        <article class="principle-card">
          <span class="principle-kicker">Engineering</span>
          <h3>Enterprise-minded delivery</h3>
          <p>Architecture, permissions, deployment, and maintainability are treated as product requirements.</p>
        </article>

        <article class="principle-card">
          <span class="principle-kicker">Partnership</span>
          <h3>Clear technical ownership</h3>
          <p>Each engagement should define scope, risks, responsibilities, and measurable delivery milestones.</p>
        </article>
      </div>
    </div>
  </Container>
</section>

<style>
  .trust-section {
    padding: var(--space-16) 0;
    background-color: var(--surface);
    border-bottom: 1px solid var(--border);
  }

  .trust-wrapper {
    display: grid;
    gap: var(--space-10);
  }

  .section-header {
    max-width: 720px;
  }

  .section-header h2 {
    margin-bottom: var(--space-3);
  }

  .section-header p {
    margin: 0;
    color: var(--text-muted);
  }

  .principles-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-5);
  }

  @media (min-width: 768px) {
    .principles-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .principle-card {
    padding: var(--space-6);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    background: var(--surface-light);
  }

  .principle-kicker {
    display: inline-block;
    margin-bottom: var(--space-3);
    color: var(--primary);
    font-size: var(--text-xs);
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .principle-card h3 {
    margin-bottom: var(--space-2);
    font-size: var(--text-xl);
  }

  .principle-card p {
    margin: 0;
    color: var(--text-muted);
    font-size: var(--text-sm);
  }
</style>
