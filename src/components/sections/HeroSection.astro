---
import Container from "../ui/Container.astro";
import Button from "../ui/Button.astro";

interface Props {
  id: string;
  title: string;
  subtitle: string;
  lang?: "es" | "en";
  primaryCtaHref?: string;
  primaryCtaLabel?: string;
  primaryCtaTarget?: string;
  secondaryCtaHref?: string;
  secondaryCtaLabel?: string;
  secondaryCtaTarget?: string;
}

const {
  id,
  title,
  subtitle,
  lang,
  primaryCtaHref,
  primaryCtaLabel,
  primaryCtaTarget,
  secondaryCtaHref,
  secondaryCtaLabel,
  secondaryCtaTarget,
} = Astro.props;
const inferredLocale = Astro.currentLocale === "es" ? "es" : "en";
const resolvedLang = lang ?? inferredLocale;
const ctaContact = {
  href: primaryCtaHref ?? (resolvedLang === "es" ? "/es/contacto/" : "/en/contact/"),
  label: primaryCtaLabel ?? (resolvedLang === "es" ? "Contactar" : "Contact Us"),
  target: primaryCtaTarget,
};

const ctaProducts = {
  href:
    secondaryCtaHref ??
    (resolvedLang === "es" ? "/es/productos/" : "/en/products/"),
  label: secondaryCtaLabel ?? (resolvedLang === "es" ? "Ver Productos" : "View Products"),
  target: secondaryCtaTarget,
};
---

<section id={id} class="hero-section">
  <div class="video-background">
    <video
      autoplay
      loop
      muted
      playsinline
      aria-hidden="true"
      class="hero-video"
    >
      <source src="/videos/hero.mp4" type="video/mp4" />
    </video>
    <div class="video-overlay"></div>
  </div>

  <Container class="hero-container">
    <div class="hero-content">
      <h1 class="hero-title">{title}</h1>
      <p class="hero-subtitle">{subtitle}</p>

      <div class="hero-actions">
        <Button href={ctaContact.href} target={ctaContact.target} size="lg" variant="glow">
          {ctaContact.label}
        </Button>
        <Button href={ctaProducts.href} target={ctaProducts.target} size="lg" variant="secondary">
          {ctaProducts.label}
        </Button>
      </div>
    </div>
  </Container>
</section>

<style>
  .hero-section {
    position: relative;
    display: flex;
    align-items: center;
    min-height: clamp(40rem, 100svh, 56rem);
    padding: clamp(6.5rem, 12vw, 8rem) 0 clamp(4rem, 10vw, 6rem);
    overflow: hidden;
    background:
      linear-gradient(180deg, color-mix(in srgb, var(--primary-soft) 44%, var(--bg)) 0%, var(--bg) 100%);
    color: var(--text);
  }

  .video-background {
    position: absolute;
    inset: 0;
    z-index: 0;
    will-change: transform;
  }

  .hero-video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: saturate(1.16) contrast(1.08) brightness(0.9);
    transform: scale(1.02);
  }

  .video-overlay {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at 18% 22%, rgba(var(--primary-rgb), 0.14), transparent 26%),
      radial-gradient(circle at 82% 18%, rgba(var(--accent-rgb), 0.12), transparent 22%),
      linear-gradient(180deg, rgba(245, 249, 253, 0.12), rgba(245, 249, 253, 0.26) 42%, rgba(245, 249, 253, 0.56));
    z-index: 1;
  }

  .hero-container {
    position: relative;
    z-index: 10;
    display: flex;
    align-items: center;
    min-height: 100%;
  }

  .hero-content {
    max-width: 54rem;
    animation: fadeInUp 0.9s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  .hero-title {
    margin-bottom: var(--space-5);
    font-size: clamp(2.45rem, 10vw, 5.25rem);
    line-height: 1.02;
    font-weight: 800;
    letter-spacing: -0.035em;
    color: #1f2730;
    text-wrap: balance;
    overflow-wrap: break-word;
    text-shadow: none;
  }

  .hero-subtitle {
    max-width: 42rem;
    margin: 0 0 var(--space-8);
    font-size: clamp(1rem, 2.7vw, 1.35rem);
    line-height: 1.65;
    color: #2f3943;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
    align-items: center;
  }

  .hero-actions :global(.btn--secondary) {
    background: color-mix(in srgb, var(--surface) 92%, white 8%);
    border-color: color-mix(in srgb, var(--primary) 12%, var(--border));
    color: var(--text);
    box-shadow: var(--shadow-sm);
  }

  .hero-actions :global(.btn--secondary:hover) {
    background: var(--surface);
    color: var(--primary);
    box-shadow: var(--shadow-md);
  }

  @media (max-width: 767px) {
    .hero-section {
      min-height: auto;
      padding-top: clamp(6.25rem, 24vw, 7rem);
      padding-bottom: var(--space-10);
      align-items: flex-end;
    }

    .hero-container {
      align-items: flex-end;
    }

    .hero-content {
      max-width: 34rem;
    }

    .hero-title {
      margin-bottom: var(--space-4);
      font-size: clamp(1.82rem, 7.8vw, 2.35rem);
      line-height: 1.08;
      letter-spacing: -0.014em;
    }

    .hero-subtitle {
      margin-bottom: var(--space-6);
      font-size: 1rem;
      max-width: 30rem;
    }

    .hero-actions {
      flex-direction: column;
      align-items: stretch;
    }

    .hero-actions :global(.btn) {
      width: 100%;
      justify-content: center;
    }
  }

  @media (min-width: 768px) and (max-width: 1023px) {
    .hero-section {
      min-height: clamp(44rem, 100svh, 52rem);
    }

    .hero-content {
      max-width: 44rem;
    }
  }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(36px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>

<script>
  function setupHeroParallax() {
    const hero = document.querySelector(".hero-section");
    const bg = document.querySelector(".video-background");

    if (!(hero instanceof HTMLElement) || !(bg instanceof HTMLElement)) {
      return;
    }

    if (
      window.innerWidth < 768 ||
      window.matchMedia("(prefers-reduced-motion: reduce)").matches
    ) {
      bg.style.transform = "";
      return;
    }

    const handleScroll = () => {
      const scrollY = window.scrollY;
      const heroHeight = hero.getBoundingClientRect().height;

      if (scrollY <= heroHeight) {
        bg.style.transform = `translate3d(0, ${scrollY * 0.22}px, 0)`;
      }
    };

    window.addEventListener("scroll", handleScroll, { passive: true });
    handleScroll();

    return () => {
      window.removeEventListener("scroll", handleScroll);
    };
  }

  let cleanupHeroParallax: (() => void) | null = null;

  document.addEventListener("astro:page-load", () => {
    if (typeof cleanupHeroParallax === "function") {
      cleanupHeroParallax();
    }

    cleanupHeroParallax = setupHeroParallax() || null;
  });
</script>
