---
import Container from "../ui/Container.astro";
import Button from "../ui/Button.astro";

interface Props {
  id: string;
  title: string;
  subtitle: string;
  lang?: "es" | "en";
}

const { id, title, subtitle, lang } = Astro.props;
const inferredLocale = Astro.currentLocale === "es" ? "es" : "en";
const resolvedLang = lang ?? inferredLocale;
const isProductPage =
  Astro.url.pathname.includes("/products/") ||
  Astro.url.pathname.includes("/productos/");

const ctaContact = {
  href: resolvedLang === "es" ? "#contacto" : "#contact",
  label: resolvedLang === "es" ? "Contactar" : "Contact Us",
};

const ctaProducts = {
  href: isProductPage
    ? resolvedLang === "es"
      ? "/es/#productos"
      : "/en/#products"
    : resolvedLang === "es"
      ? "#productos"
      : "#products",
  label: resolvedLang === "es" ? "Ver Productos" : "View Products",
};
---

<section id={id} class="hero-section">
  <div class="video-background">
    <video
      autoplay
      loop
      muted
      playsinline
      poster="/images/hero-poster.jpg"
      class="hero-video"
    >
      <source src="/videos/hero.mp4" type="video/mp4" />
    </video>
    <div class="video-overlay"></div>
  </div>

  <Container class="hero-container">
    <div class="hero-content">
      <h1 class="hero-title">{title}</h1>
      <p class="hero-subtitle">{subtitle}</p>

      <div class="hero-actions">
        <Button href={ctaContact.href} size="lg" variant="glass">
          {ctaContact.label}
        </Button>
        <Button href={ctaProducts.href} size="lg" variant="glass">
          {ctaProducts.label}
        </Button>
      </div>
    </div>
  </Container>
</section>

<style>
  .hero-section {
    position: relative;
    display: flex;
    align-items: center;
    min-height: clamp(40rem, 100svh, 56rem);
    padding: clamp(6.5rem, 12vw, 8rem) 0 clamp(4rem, 10vw, 6rem);
    overflow: hidden;
    background-color: #020617;
    color: #f8fafc;
  }

  .video-background {
    position: absolute;
    inset: 0;
    z-index: 0;
    will-change: transform;
  }

  .hero-video {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .video-overlay {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at 50% 40%, rgba(37, 99, 235, 0.16), transparent 34%),
      linear-gradient(180deg, rgba(2, 6, 23, 0.34), rgba(2, 6, 23, 0.78) 52%, rgba(2, 6, 23, 0.96));
    z-index: 1;
  }

  .hero-container {
    position: relative;
    z-index: 10;
    display: flex;
    align-items: center;
    min-height: 100%;
  }

  .hero-content {
    max-width: 54rem;
    animation: fadeInUp 0.9s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  .hero-title {
    margin-bottom: var(--space-5);
    font-size: clamp(2.5rem, 11vw, 5.5rem);
    line-height: 0.98;
    font-weight: 900;
    letter-spacing: -0.06em;
    color: #f8fafc;
    text-wrap: balance;
    text-shadow: 0 16px 32px rgba(2, 6, 23, 0.32);
  }

  .hero-subtitle {
    max-width: 42rem;
    margin: 0 0 var(--space-8);
    font-size: clamp(1rem, 2.7vw, 1.35rem);
    line-height: 1.65;
    color: rgba(226, 232, 240, 0.88);
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
    align-items: center;
  }

  @media (max-width: 767px) {
    .hero-section {
      min-height: auto;
      padding-top: clamp(6.25rem, 24vw, 7rem);
      padding-bottom: var(--space-10);
      align-items: flex-end;
    }

    .hero-container {
      align-items: flex-end;
    }

    .hero-content {
      max-width: 34rem;
    }

    .hero-title {
      margin-bottom: var(--space-4);
      font-size: clamp(2.35rem, 13vw, 3.45rem);
    }

    .hero-subtitle {
      margin-bottom: var(--space-6);
      font-size: 1rem;
      max-width: 30rem;
    }

    .hero-actions {
      flex-direction: column;
      align-items: stretch;
    }

    .hero-actions :global(.btn) {
      width: 100%;
      justify-content: center;
    }
  }

  @media (min-width: 768px) and (max-width: 1023px) {
    .hero-section {
      min-height: clamp(44rem, 100svh, 52rem);
    }

    .hero-content {
      max-width: 44rem;
    }
  }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(36px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>

<script>
  function setupHeroParallax() {
    const hero = document.querySelector(".hero-section");
    const bg = document.querySelector(".video-background");

    if (!(hero instanceof HTMLElement) || !(bg instanceof HTMLElement)) {
      return;
    }

    if (
      window.innerWidth < 768 ||
      window.matchMedia("(prefers-reduced-motion: reduce)").matches
    ) {
      bg.style.transform = "";
      return;
    }

    const handleScroll = () => {
      const scrollY = window.scrollY;
      const heroHeight = hero.getBoundingClientRect().height;

      if (scrollY <= heroHeight) {
        bg.style.transform = `translate3d(0, ${scrollY * 0.22}px, 0)`;
      }
    };

    window.addEventListener("scroll", handleScroll, { passive: true });
    handleScroll();

    return () => {
      window.removeEventListener("scroll", handleScroll);
    };
  }

  let cleanupHeroParallax: (() => void) | null = null;

  document.addEventListener("astro:page-load", () => {
    if (typeof cleanupHeroParallax === "function") {
      cleanupHeroParallax();
    }

    cleanupHeroParallax = setupHeroParallax() || null;
  });
</script>
