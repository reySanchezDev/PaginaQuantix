---
import Container from "../ui/Container.astro";

interface Props {
  navItems: { label: string; href: string }[];
  lang: "es" | "en";
}

const { navItems, lang } = Astro.props;
const year = new Date().getFullYear();
const homeHref = lang === "es" ? "/es/" : "/en/";
const privacyHref = lang === "es" ? "/es/privacidad/" : "/en/privacy/";
const termsHref = lang === "es" ? "/es/terminos/" : "/en/terms/";
const communityHref = lang === "es" ? "/es/comunidad/" : "/en/community/";
const homeAria =
  lang === "es" ? "Inicio de Quantix Software" : "Quantix Software Home";
const texts =
  lang === "es"
    ? {
        tagline: "Software empresarial para control operativo.",
        navTitle: "Navegación",
        resourcesTitle: "Recursos profesionales",
        community: "Comunidad",
        legalTitle: "Legal",
        privacy: "Privacidad",
        terms: "Términos",
        rights: "Todos los derechos reservados.",
      }
    : {
        tagline: "Business software for operational control.",
        navTitle: "Navigation",
        resourcesTitle: "Professional Resources",
        community: "Community",
        legalTitle: "Legal",
        privacy: "Privacy",
        terms: "Terms",
        rights: "All rights reserved.",
      };
---

<footer class="footer-premium">
  <Container>
    <div class="footer-content">
      <div class="brand-col">
        <a href={homeHref} class="brand-logo" aria-label={homeAria}>
          <img src="/favicon.svg" alt="Quantix Logo" width="28" height="28" />
          <span class="brand-wordmark">Quantix</span>
        </a>
        <p class="tagline">{texts.tagline}</p>
      </div>

      <div class="nav-col">
        <h4 class="col-title">{texts.navTitle}</h4>
        <ul class="footer-nav">
          {
            navItems.map((item) => (
              <li><a href={item.href}>{item.label}</a></li>
            ))
          }
        </ul>
      </div>

      <div class="resources-col">
        <h4 class="col-title">{texts.resourcesTitle}</h4>
        <ul class="footer-nav">
          <li><a href={communityHref}>{texts.community}</a></li>
        </ul>
      </div>

      <div class="legal-col">
        <h4 class="col-title">{texts.legalTitle}</h4>
        <ul class="footer-nav">
          <li><a href={privacyHref}>{texts.privacy}</a></li>
          <li><a href={termsHref}>{texts.terms}</a></li>
        </ul>
      </div>
    </div>

    <div class="footer-bottom">
      <p>&copy; {year} Quantix Software. {texts.rights}</p>
    </div>
  </Container>
</footer>

<style>
  .footer-premium {
    background:
      linear-gradient(180deg, color-mix(in srgb, var(--surface) 78%, var(--bg)) 0%, var(--surface) 100%);
    border-top: 1px solid var(--border);
    padding: clamp(var(--space-10), 7vw, var(--space-16)) 0 var(--space-8);
    margin-top: auto;
  }

  .footer-content {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-8);
    margin-bottom: var(--space-12);
  }

  @media (min-width: 768px) {
    .footer-content {
      grid-template-columns: minmax(16rem, 2fr) repeat(3, minmax(8rem, 1fr));
      align-items: start;
    }
  }

  .brand-col {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .brand-logo {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    width: fit-content;
    color: var(--text);
    text-decoration: none;
  }

  .brand-wordmark {
    font-family: var(--font-heading);
    font-size: var(--text-xl);
    font-weight: 700;
    letter-spacing: -0.01em;
  }

  .tagline {
    color: var(--text-muted);
    font-size: var(--text-sm);
    max-width: 300px;
    line-height: 1.65;
  }

  .col-title {
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.09em;
    font-weight: 700;
    color: var(--text);
    margin: 0 0 var(--space-4);
  }

  .footer-nav {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .footer-nav a {
    color: var(--text-muted);
    text-decoration: none;
    font-size: var(--text-sm);
    line-height: 1.5;
    transition: color 0.2s ease;
  }

  .footer-nav a:hover {
    color: var(--primary);
  }

  .footer-bottom {
    padding-top: var(--space-8);
    border-top: 1px solid var(--border);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-4);
    color: var(--text-subtle);
    font-size: var(--text-xs);
  }

  .footer-bottom p {
    margin: 0;
  }

  @media (min-width: 768px) {
    .footer-bottom {
      flex-direction: row;
      justify-content: space-between;
      text-align: left;
    }
  }
</style>
