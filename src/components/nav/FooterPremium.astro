---
import Container from "../ui/Container.astro";

interface Props {
  navItems: { label: string; href: string }[];
  lang: "es" | "en";
}

const { navItems, lang } = Astro.props;
const year = new Date().getFullYear();
const homeHref = lang === "es" ? "/es/" : "/en/";
const homeAria =
  lang === "es" ? "Inicio de Quantix Software" : "Quantix Software Home";
const texts =
  lang === "es"
    ? {
        tagline: "Soluciones de software de nivel empresarial.",
        navTitle: "Navegacion",
        legalTitle: "Legal",
        privacy: "Privacidad",
        terms: "Terminos",
        rights: "Todos los derechos reservados.",
      }
    : {
        tagline: "Enterprise-grade software solutions.",
        navTitle: "Navigation",
        legalTitle: "Legal",
        privacy: "Privacy",
        terms: "Terms",
        rights: "All rights reserved.",
      };
---

<footer class="footer-premium">
  <Container>
    <div class="footer-content">
      <div class="brand-col">
        <a href={homeHref} class="brand-logo" aria-label={homeAria}>
          <svg
            class="logo"
            width="100"
            height="40"
            viewBox="0 0 100 40"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
          >
            <text
              x="0"
              y="26"
              font-family="var(--font-heading)"
              font-size="20"
              font-weight="bold"
              fill="var(--text)">Quantix</text
            >
          </svg>
        </a>
        <p class="tagline">{texts.tagline}</p>
      </div>

      <div class="nav-col">
        <h4 class="col-title">{texts.navTitle}</h4>
        <ul class="footer-nav">
          {
            navItems.map((item) => (
              <li><a href={item.href}>{item.label}</a></li>
            ))
          }
        </ul>
      </div>

      <div class="legal-col">
        <h4 class="col-title">{texts.legalTitle}</h4>
        <ul class="footer-nav">
          <li><a href="#">{texts.privacy}</a></li>
          <li><a href="#">{texts.terms}</a></li>
        </ul>
      </div>
    </div>

    <div class="footer-bottom">
      <p>&copy; {year} Quantix Software. {texts.rights}</p>
    </div>
  </Container>
</footer>

<style>
  .footer-premium {
    background-color: var(--surface);
    border-top: 1px solid var(--border);
    padding: var(--space-12) 0 var(--space-8);
    margin-top: auto;
  }

  .footer-content {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-10);
    margin-bottom: var(--space-12);
  }

  @media (min-width: 768px) {
    .footer-content {
      grid-template-columns: 2fr 1fr 1fr;
    }
  }

  .brand-col {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .tagline {
    color: var(--text-muted);
    font-size: var(--text-sm);
    max-width: 300px;
    line-height: 1.6;
  }

  .col-title {
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-weight: 700;
    color: var(--text);
    margin-bottom: var(--space-6);
  }

  .footer-nav {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .footer-nav a {
    color: var(--text-muted);
    text-decoration: none;
    font-size: var(--text-sm);
    transition: all 0.2s ease;
  }

  .footer-nav a:hover {
    color: var(--primary);
    transform: translateX(2px);
  }

  .footer-bottom {
    padding-top: var(--space-8);
    border-top: 1px solid var(--border);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-4);
    color: var(--text-subtle);
    font-size: var(--text-xs);
  }

  @media (min-width: 768px) {
    .footer-bottom {
      flex-direction: row;
      justify-content: space-between;
      text-align: left;
    }
  }
</style>
