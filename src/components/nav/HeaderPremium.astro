---
import Container from "../ui/Container.astro";
import LanguageSwitch from "./LanguageSwitch.astro";
import MobileMenu from "./MobileMenu.astro";

interface Props {
  navItems: { label: string; href: string }[];
  lang: "es" | "en";
  isTransparent?: boolean;
}

const { navItems, lang, isTransparent = true } = Astro.props;
const homeHref = lang === "es" ? "/es/" : "/en/";
const homeAria =
  lang === "es" ? "Inicio de Quantix Software" : "Quantix Software Home";
const openMenuAria = lang === "es" ? "Abrir menu" : "Open menu";
---

<header
  id="main-header"
  class:list={["header-premium", { scrolled: !isTransparent }]}
  data-transparent={isTransparent.toString()}
>
  <Container class="header-container">
    <nav class="desktop-nav" aria-label={lang === "es" ? "Navegacion principal" : "Primary navigation"}>
      <div class="segmented-control">
        <a href={homeHref} class="brand-logo" aria-label={homeAria}>
          <img src="/favicon.svg" alt="Quantix Logo" width="32" height="32" class="header-favicon" />
          <svg
            class="logo"
            width="100"
            height="36"
            viewBox="0 0 100 40"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
          >
            <text
              x="0"
              y="27"
              font-family="var(--font-heading)"
              font-size="24"
              font-weight="bold"
              fill="white">Quantix</text
            >
          </svg>
        </a>

        <div class="nav-pill-separator"></div>

        <div class="nav-links-wrapper">
          <div id="nav-indicator" class="nav-indicator"></div>
          {
            navItems.map((item) => (
              <a
                href={item.href}
                class="nav-link"
                data-target={item.href.split("#")[1]}
              >
                {item.label}
              </a>
            ))
          }
        </div>

        <div class="nav-pill-separator"></div>

        <div class="nav-settings-integrated">
          <LanguageSwitch />
        </div>
      </div>
    </nav>

    <div class="mobile-header mobile-only">
      <a href={homeHref} class="brand-logo-mobile" aria-label={homeAria}>
        <img src="/favicon.svg" alt="Quantix Logo" width="28" height="28" class="header-favicon mobile-favicon" />
        <span class="mobile-logo-text">Quantix</span>
      </a>

      <button
        id="mobile-menu-toggle"
        type="button"
        class="mobile-toggle"
        aria-label={openMenuAria}
        aria-controls="mobile-menu-overlay"
        aria-expanded="false"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="22"
          height="22"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <line x1="3" y1="12" x2="21" y2="12"></line>
          <line x1="3" y1="6" x2="21" y2="6"></line>
          <line x1="3" y1="18" x2="21" y2="18"></line>
        </svg>
      </button>
    </div>
  </Container>
</header>

<MobileMenu navItems={navItems} lang={lang} />

<style>
  .header-premium {
    position: fixed;
    inset: 0 0 auto 0;
    z-index: 50;
    padding: clamp(0.85rem, 2.5vw, 1.5rem) 0;
    transition:
      padding 0.3s ease,
      transform 0.3s ease;
  }

  .header-premium.scrolled,
  .header-premium[data-transparent="false"] {
    padding: 0.7rem 0;
  }

  .header-container {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    position: relative;
    padding-inline: clamp(0.9rem, 3vw, 1.5rem);
  }

  .desktop-nav {
    display: none;
  }

  .segmented-control {
    display: flex;
    align-items: center;
    padding: 0.45rem 0.75rem;
    background: rgba(255, 255, 255, 0.06);
    backdrop-filter: blur(18px);
    -webkit-backdrop-filter: blur(18px);
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 999px;
    position: relative;
    margin: 0 auto;
    box-shadow:
      0 16px 48px rgba(2, 6, 23, 0.16),
      inset 0 1px 1px rgba(255, 255, 255, 0.08);
  }

  .header-premium.scrolled .segmented-control,
  .header-premium[data-transparent="false"] .segmented-control {
    background: color-mix(in srgb, var(--surface) 88%, transparent);
    border-color: color-mix(in srgb, var(--border-strong) 88%, transparent);
    box-shadow: var(--shadow-lg);
  }

  .brand-logo,
  .brand-logo-mobile {
    display: flex;
    align-items: center;
    gap: 0;
    text-decoration: none;
  }

  .brand-logo {
    padding-left: var(--space-2);
    transition: transform 0.3s ease;
  }

  .brand-logo:hover {
    transform: scale(1.03);
  }

  .header-favicon {
    margin-right: -14px;
  }

  .mobile-favicon {
    margin-right: 0.18rem;
  }

  .brand-logo-mobile {
    gap: 0.1rem;
  }

  .logo {
    width: 130px;
    height: 36px;
  }

  .nav-links-wrapper {
    display: flex;
    position: relative;
    align-items: center;
  }

  .nav-link {
    position: relative;
    z-index: 2;
    padding: 0.7rem 1.35rem;
    text-decoration: none;
    color: rgba(255, 255, 255, 0.74);
    font-size: var(--text-sm);
    font-weight: 600;
    transition:
      color 0.25s ease,
      transform 0.25s ease;
    border-radius: 999px;
  }

  .nav-link:hover {
    color: rgba(248, 250, 252, 1);
  }

  .nav-link.active {
    color: white;
  }

  .header-premium.scrolled .nav-link,
  .header-premium[data-transparent="false"] .nav-link {
    color: var(--text-muted);
  }

  .header-premium.scrolled .nav-link:hover,
  .header-premium[data-transparent="false"] .nav-link:hover {
    color: var(--text);
  }

  .header-premium.scrolled .nav-link.active,
  .header-premium[data-transparent="false"] .nav-link.active {
    color: var(--primary);
  }

  .nav-indicator {
    position: absolute;
    top: 4px;
    bottom: 4px;
    left: 0;
    width: 0;
    background: rgba(255, 255, 255, 0.16);
    border-radius: 999px;
    z-index: 1;
    opacity: 0;
    transition: all 0.35s cubic-bezier(0.25, 0.8, 0.25, 1);
  }

  .header-premium.scrolled .nav-indicator,
  .header-premium[data-transparent="false"] .nav-indicator {
    background: var(--surface);
    box-shadow: var(--shadow-md);
    border: 1px solid var(--border);
  }

  .nav-pill-separator {
    width: 1px;
    height: 24px;
    background: rgba(255, 255, 255, 0.14);
    margin: 0 8px;
    flex-shrink: 0;
  }

  .header-premium.scrolled .nav-pill-separator,
  .header-premium[data-transparent="false"] .nav-pill-separator {
    background: var(--border-strong);
  }

  .nav-settings-integrated {
    display: flex;
    align-items: center;
    gap: 0.2rem;
    z-index: 10;
    padding-right: 0.15rem;
  }

  .header-premium :global(.lang-switch) {
    padding: 0.5rem 0.7rem;
    border-radius: 999px;
    color: rgba(255, 255, 255, 0.9);
  }

  .header-premium.scrolled :global(.lang-switch),
  .header-premium[data-transparent="false"] :global(.lang-switch) {
    color: var(--text-muted);
  }

  .header-premium.scrolled .brand-logo :global(text),
  .header-premium[data-transparent="false"] .brand-logo :global(text) {
    fill: var(--text);
  }

  .mobile-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-3);
    width: 100%;
    padding: 0.75rem 0.9rem;
    border-radius: 1.5rem;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.08), rgba(255, 255, 255, 0.03)),
      rgba(2, 6, 23, 0.38);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border: 1px solid rgba(255, 255, 255, 0.12);
    box-shadow:
      0 18px 40px rgba(2, 6, 23, 0.2),
      inset 0 1px 0 rgba(255, 255, 255, 0.08);
  }

  .header-premium.scrolled .mobile-header,
  .header-premium[data-transparent="false"] .mobile-header {
    background:
      linear-gradient(180deg, color-mix(in srgb, var(--surface) 94%, white 6%), color-mix(in srgb, var(--surface) 98%, transparent)),
      color-mix(in srgb, var(--surface) 95%, transparent);
    border-color: color-mix(in srgb, var(--border-strong) 88%, transparent);
    box-shadow: var(--shadow-lg);
  }

  .mobile-logo-text {
    font-family: var(--font-heading);
    font-size: clamp(1.05rem, 3.8vw, 1.2rem);
    font-weight: 700;
    color: white;
    letter-spacing: -0.03em;
  }

  .header-premium.scrolled .mobile-logo-text,
  .header-premium[data-transparent="false"] .mobile-logo-text {
    color: var(--text);
  }

  .mobile-toggle {
    inline-size: 2.75rem;
    block-size: 2.75rem;
    border-radius: 999px;
    border: 1px solid rgba(255, 255, 255, 0.12);
    background: rgba(255, 255, 255, 0.06);
    color: white;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition:
      transform 0.25s ease,
      background-color 0.25s ease,
      border-color 0.25s ease;
  }

  .mobile-toggle:hover {
    transform: translateY(-1px);
  }

  .header-premium.scrolled .mobile-toggle,
  .header-premium[data-transparent="false"] .mobile-toggle {
    color: var(--text);
    background: var(--surface-2);
    border-color: var(--border);
  }

  @media (max-width: 767px) {
    .header-container {
      padding-inline: 0.9rem;
    }

    .mobile-header {
      border-radius: 1.35rem;
      padding: 0.7rem 0.75rem;
    }
  }

  @media (min-width: 1024px) {
    .desktop-nav {
      display: flex;
    }

    .mobile-header {
      display: none;
    }
  }

  @media (max-width: 1023px) {
    .desktop-nav {
      display: none;
    }
  }

  @media (min-width: 1024px) {
    .mobile-only {
      display: none;
    }
  }
</style>

<script>
  function setupHeader() {
    const header = document.getElementById("main-header");
    const isInitialTransparent = header?.dataset.transparent === "true";
    const toggleBtn = document.getElementById("mobile-menu-toggle");
    const overlay = document.getElementById("mobile-menu-overlay");

    if (!header) {
      return;
    }

    const updateScroll = () => {
      if (window.scrollY > 20 || !isInitialTransparent) {
        header.classList.add("scrolled");
      } else {
        header.classList.remove("scrolled");
      }
    };

    window.addEventListener("scroll", updateScroll, { passive: true });
    updateScroll();

    const openMenu = () => {
      overlay?.classList.add("open");
      toggleBtn?.setAttribute("aria-expanded", "true");
      document.body.style.overflow = "hidden";
    };

    if (toggleBtn && toggleBtn.dataset.bound !== "true") {
      toggleBtn.addEventListener("click", openMenu);
      toggleBtn.dataset.bound = "true";
    }

    const links = document.querySelectorAll(".nav-link");
    const indicator = document.getElementById("nav-indicator");

    const updateIndicator = (targetLink: Element | null) => {
      if (!(targetLink instanceof HTMLElement) || !indicator) {
        return;
      }

      const linkRect = targetLink.getBoundingClientRect();
      const parentRect = targetLink.parentElement?.getBoundingClientRect();

      if (!parentRect) {
        return;
      }

      indicator.style.width = `${linkRect.width}px`;
      indicator.style.transform = `translateX(${linkRect.left - parentRect.left}px)`;
      indicator.style.opacity = "1";
      links.forEach((link) => link.classList.remove("active"));
      targetLink.classList.add("active");
    };

    links.forEach((link) => {
      if (!(link instanceof HTMLElement) || link.dataset.bound === "true") {
        return;
      }

      link.addEventListener("click", () => updateIndicator(link));
      link.dataset.bound = "true";
    });

    const observerOptions = {
      root: null,
      rootMargin: "-20% 0px -60% 0px",
      threshold: 0,
    };

    const spyObserver = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (!entry.isIntersecting) {
          return;
        }

        const id = entry.target.getAttribute("id");
        if (!id) {
          return;
        }

        const targetLink = document.querySelector(`.nav-link[data-target="${id}"]`);
        updateIndicator(targetLink);
      });
    }, observerOptions);

    document.querySelectorAll("section[id]").forEach((section) => {
      spyObserver.observe(section);
    });

    return () => {
      window.removeEventListener("scroll", updateScroll);
      spyObserver.disconnect();
    };
  }

  let cleanupHeader: (() => void) | null = null;

  document.addEventListener("astro:page-load", () => {
    if (typeof cleanupHeader === "function") {
      cleanupHeader();
    }

    cleanupHeader = setupHeader() || null;
  });
</script>
