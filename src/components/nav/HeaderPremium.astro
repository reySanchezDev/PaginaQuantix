---
import Container from "../ui/Container.astro";
import LanguageSwitch from "./LanguageSwitch.astro";
import MobileMenu from "./MobileMenu.astro";

interface Props {
  navItems: { label: string; href: string }[];
  lang: "es" | "en";
  isTransparent?: boolean;
}

const { navItems, lang, isTransparent = true } = Astro.props;
const homeHref = lang === "es" ? "/es/" : "/en/";
const homeAria =
  lang === "es" ? "Inicio de Quantix Software" : "Quantix Software Home";
const openMenuAria = lang === "es" ? "Abrir menu" : "Open menu";
---

<header id="main-header" class:list={["header-premium", { "scrolled": !isTransparent }]} data-transparent={isTransparent.toString()}>
  <Container class="header-container">
    <!-- Unified Super Pill Nav -->
    <nav class="desktop-nav">
      <div class="segmented-control">
        <!-- Logo Integrated on the left -->
        <a href={homeHref} class="brand-logo" aria-label={homeAria}>
          <svg
            class="logo"
            width="100"
            height="36"
            viewBox="0 0 100 40"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
          >
            <text
              x="0"
              y="27"
              font-family="var(--font-heading)"
              font-size="24"
              font-weight="bold"
              fill="white">Quantix</text
            >
          </svg>
        </a>

        <div class="nav-pill-separator"></div>

        <!-- Links -->
        <div class="nav-links-wrapper">
          <div id="nav-indicator" class="nav-indicator"></div>
          {
            navItems.map((item) => (
              <a
                href={item.href}
                class="nav-link"
                data-target={item.href.split("#")[1]}
              >
                {item.label}
              </a>
            ))
          }
        </div>

        <div class="nav-pill-separator"></div>

        <!-- Settings Integrated on the right -->
        <div class="nav-settings-integrated">
          <LanguageSwitch />
        </div>
      </div>
    </nav>

    <!-- Mobile Header (Logo stays visible) -->
    <div class="mobile-header mobile-only">
      <a href={homeHref} class="brand-logo-mobile" aria-label={homeAria}>
        <span class="mobile-logo-text">Quantix</span>
      </a>

      <button
        id="mobile-menu-toggle"
        class="mobile-toggle"
        aria-label={openMenuAria}
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="24"
          height="24"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <line x1="3" y1="12" x2="21" y2="12"></line>
          <line x1="3" y1="6" x2="21" y2="6"></line>
          <line x1="3" y1="18" x2="21" y2="18"></line>
        </svg>
      </button>
    </div>
  </Container>
</header>
<MobileMenu navItems={navItems} lang={lang} />

<style>
  .header-premium {
    position: fixed;
    top: 0;
    z-index: 50;
    width: 100%;
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    padding: var(--space-6) 0;
    background: transparent;
  }

  @media (max-width: 1023px) {
    .header-premium {
      position: absolute;
      padding: var(--space-4) 0;
    }
  }

  /* Solid state background Fix */
  .header-premium.scrolled,
  .header-premium[data-transparent="false"] {
    padding: var(--space-4) 0;
  }

  .header-container {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    position: relative;
    padding: 0 var(--space-4);
  }

  .segmented-control {
    display: flex;
    align-items: center;
    padding: 6px 12px;
    background: rgba(255, 255, 255, 0.05); /* Glass */
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 9999px;
    position: relative;
    margin: 0 auto;
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.2), inset 0 1px 1px rgba(255, 255, 255, 0.1);
  }

  /* Solid logic for both scrolled and data attribute */
  .header-premium.scrolled .segmented-control,
  .header-premium[data-transparent="false"] .segmented-control {
    background: var(--surface);
    border-color: var(--border-strong);
    box-shadow: var(--shadow-lg), 0 0 20px rgba(0, 0, 0, 0.05);
  }

  .brand-logo {
    display: flex;
    align-items: center;
    padding-left: var(--space-2);
    transition: transform 0.3s ease;
  }

  .brand-logo:hover {
    transform: scale(1.05);
  }

  .logo {
    width: 130px;
    height: 36px;
  }

  .nav-links-wrapper {
    display: flex;
    position: relative;
    align-items: center;
  }

  .desktop-nav {
    display: none;
  }

  .mobile-header {
    display: flex;
    width: 100%;
    max-width: 450px;
    justify-content: space-between;
    align-items: center;
    padding: 6px 16px;
    background: rgba(255, 255, 255, 0.05);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 9999px;
    margin: 0 auto;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.15);
  }

  .mobile-logo-text {
    font-family: var(--font-heading);
    font-size: var(--text-lg);
    font-weight: 700;
    color: white;
    letter-spacing: -0.02em;
  }

  .header-premium.scrolled .mobile-logo-text,
  .header-premium[data-transparent="false"] .mobile-logo-text {
    color: var(--text);
  }

  @media (min-width: 1024px) {
    .desktop-nav {
      display: flex;
    }
    .mobile-header {
      display: none;
    }
  }

  .nav-link {
    position: relative;
    z-index: 2;
    padding: 10px 24px;
    text-decoration: none;
    color: rgba(255, 255, 255, 0.7);
    font-size: var(--text-sm);
    font-weight: 600;
    transition: all 0.3s ease;
    border-radius: 9999px;
  }

  .nav-link:hover { color: #ffffff; }
  .nav-link.active { color: white; }

  /* Text color override for solid state */
  .header-premium.scrolled .nav-link,
  .header-premium[data-transparent="false"] .nav-link {
    color: var(--text-muted);
  }
  .header-premium.scrolled .nav-link:hover,
  .header-premium[data-transparent="false"] .nav-link:hover {
    color: var(--text);
  }
  .header-premium.scrolled .nav-link.active,
  .header-premium[data-transparent="false"] .nav-link.active {
    color: var(--primary);
  }

  .nav-indicator {
    position: absolute;
    top: 4px;
    bottom: 4px;
    left: 0;
    width: 0;
    background: rgba(255, 255, 255, 0.2);
    border-radius: 9999px;
    z-index: 1;
    opacity: 0;
    transition: all 0.4s cubic-bezier(0.25, 0.8, 0.25, 1);
  }

  .header-premium.scrolled .nav-indicator,
  .header-premium[data-transparent="false"] .nav-indicator {
    background: var(--surface);
    box-shadow: var(--shadow-md);
    border: 1px solid var(--border);
  }

  .nav-pill-separator {
    width: 1px;
    height: 24px;
    background: rgba(255, 255, 255, 0.15);
    margin: 0 8px;
    flex-shrink: 0;
  }

  .header-premium.scrolled .nav-pill-separator,
  .header-premium[data-transparent="false"] .nav-pill-separator {
    background: var(--border-strong);
    height: 20px;
  }

  .nav-settings-integrated {
    display: flex;
    align-items: center;
    gap: 2px;
    z-index: 10;
    padding-right: 4px;
  }

  .header-premium :global(.lang-switch) {
    padding: 6px 10px;
    border-radius: 999px;
    color: rgba(255, 255, 255, 0.9);
  }

  .header-premium.scrolled :global(.lang-switch),
  .header-premium[data-transparent="false"] :global(.lang-switch) {
    color: var(--text-muted);
  }

  /* Logo text color fix */
  .header-premium.scrolled .brand-logo :global(text),
  .header-premium[data-transparent="false"] .brand-logo :global(text) {
    fill: var(--text);
  }

  .header-premium.scrolled .brand-logo :global(path),
  .header-premium[data-transparent="false"] .brand-logo :global(path) {
    fill: var(--text);
  }

  .mobile-toggle {
    background: none;
    border: none;
    color: white;
    padding: var(--space-2);
    cursor: pointer;
    transition: color 0.3s;
  }

  .header-premium.scrolled .mobile-toggle,
  .header-premium[data-transparent="false"] .mobile-toggle {
    color: var(--text);
  }

  @media (min-width: 1024px) {
    .mobile-only { display: none; }
  }
</style>

<script>
  function setupHeader() {
    const header = document.getElementById("main-header");
    const isInitialTransparent = header?.dataset.transparent === "true";

    function updateScroll() {
        if (window.scrollY > 20 || !isInitialTransparent) {
            header?.classList.add("scrolled");
        } else {
            header?.classList.remove("scrolled");
        }
    }

    window.addEventListener("scroll", updateScroll);
    updateScroll();

    const toggleBtn = document.getElementById("mobile-menu-toggle");
    const overlay = document.getElementById("mobile-menu-overlay");

    toggleBtn?.addEventListener("click", () => {
      overlay?.classList.add("open");
      document.body.style.overflow = "hidden";
    });

    const links = document.querySelectorAll(".nav-link");
    const indicator = document.getElementById("nav-indicator");

    function updateIndicator(targetLink: Element | null) {
      if (!targetLink || !indicator) return;
      const linkRect = targetLink.getBoundingClientRect();
      const parentRect = targetLink.parentElement!.getBoundingClientRect();
      indicator.style.width = `${linkRect.width}px`;
      indicator.style.transform = `translateX(${linkRect.left - parentRect.left}px)`;
      indicator.classList.add("visible");
      links.forEach((l) => l.classList.remove("active"));
      targetLink.classList.add("active");
    }

    links.forEach((link) => {
      link.addEventListener("click", () => updateIndicator(link));
    });

    const observerOptions = {
      root: null,
      rootMargin: "-20% 0px -60% 0px",
      threshold: 0,
    };

    const spyObserver = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const id = entry.target.getAttribute("id");
          if (!id) return;
          const targetLink = document.querySelector(`.nav-link[data-target="${id}"]`);
          if (targetLink) updateIndicator(targetLink);
        }
      });
    }, observerOptions);

    document.querySelectorAll("section[id]").forEach((section) => {
      spyObserver.observe(section);
    });

    return () => {
        window.removeEventListener("scroll", updateScroll);
        spyObserver.disconnect();
    };
  }

  let cleanupHeader: (() => void) | null | void = null;
  
  document.addEventListener("astro:page-load", () => {
      if (typeof cleanupHeader === 'function') {
          cleanupHeader();
      }
      cleanupHeader = setupHeader();
  });
</script>
