---
const { currentLocale } = Astro;
const { pathname } = Astro.url;

const locale = currentLocale === "es" ? "es" : "en";
const targetLocale = locale === "es" ? "en" : "es";
const ariaLabel =
  locale === "es"
    ? `Cambiar idioma a ${targetLocale.toUpperCase()}`
    : `Change language to ${targetLocale.toUpperCase()}`;

const normalizePath = (value: string) => {
  if (value === "/") return "/";
  return value.endsWith("/") ? value : `${value}/`;
};

const routePairs: Record<string, string> = {
  "/es/": "/en/",
  "/en/": "/es/",
  "/es/productos/takofy/": "/en/products/takofy/",
  "/en/products/takofy/": "/es/productos/takofy/",
  "/es/productos/nica-finanzas/": "/en/products/nica-finanzas/",
  "/en/products/nica-finanzas/": "/es/productos/nica-finanzas/",
  "/es/soluciones/": "/en/solutions/",
  "/en/solutions/": "/es/soluciones/",
  "/es/productos/": "/en/products/",
  "/en/products/": "/es/productos/",
  "/es/trabajo/": "/en/work/",
  "/en/work/": "/es/trabajo/",
  "/es/nosotros/": "/en/about/",
  "/en/about/": "/es/nosotros/",
  "/es/contacto/": "/en/contact/",
  "/en/contact/": "/es/contacto/",
  "/es/comunidad/": "/en/community/",
  "/en/community/": "/es/comunidad/",
  "/es/privacidad/": "/en/privacy/",
  "/en/privacy/": "/es/privacidad/",
  "/es/terminos/": "/en/terms/",
  "/en/terms/": "/es/terminos/",
};

const normalizedPathname = normalizePath(pathname);

let targetPath = routePairs[normalizedPathname];
if (!targetPath) {
  if (normalizedPathname.startsWith("/es/")) {
    targetPath = normalizedPathname.replace("/es/", "/en/");
  } else if (normalizedPathname.startsWith("/en/")) {
    targetPath = normalizedPathname.replace("/en/", "/es/");
  } else {
    targetPath = `/${targetLocale}/`;
  }
}
---

<a href={targetPath} class="lang-switch" aria-label={ariaLabel}>
  <span class:list={["lang-code", { active: locale === "es" }]}>ES</span>
  <span class="divider">/</span>
  <span class:list={["lang-code", { active: locale === "en" }]}>EN</span>
</a>

<style>
  .lang-switch {
    display: flex;
    align-items: center;
    gap: 4px;
    font-size: var(--text-sm);
    font-weight: 500;
    text-decoration: none;
    color: var(--text-muted);
    padding: var(--space-2);
    border-radius: var(--radius-md);
    transition: color 0.2s ease, background-color 0.2s ease;
  }

  .lang-switch:hover {
    color: var(--text);
    background-color: var(--surface-2);
  }

  .lang-code {
    opacity: 0.5;
    transition: opacity 0.2s ease;
  }

  .lang-code.active {
    opacity: 1;
    font-weight: 700;
    color: var(--text);
  }

  .divider {
    opacity: 0.3;
  }
</style>
