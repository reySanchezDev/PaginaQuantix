---
import HeaderPremium from "../components/nav/HeaderPremium.astro";
import FooterPremium from "../components/nav/FooterPremium.astro";
import ScrollToTop from "../components/ui/ScrollToTop.astro";
import { ViewTransitions } from "astro:transitions";
import "../styles/global.css";

interface Props {
  title: string;
  description: string;
  lang?: "es" | "en";
}

const { title, description, lang = "en" } = Astro.props;

const homePath = lang === "es" ? "/es/" : "/en/";
const navItems =
  lang === "es"
    ? [
        { label: "Inicio", href: `${homePath}#inicio` },
        { label: "Servicios", href: `${homePath}#funciones` },
        { label: "Productos", href: `${homePath}#productos` },
        { label: "Contacto", href: `${homePath}#contacto` },
      ]
    : [
        { label: "Home", href: `${homePath}#home` },
        { label: "Features", href: `${homePath}#features` },
        { label: "Products", href: `${homePath}#products` },
        { label: "Contact", href: `${homePath}#contact` },
      ];
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title} | Quantix Software</title>

    <ViewTransitions />
  </head>
  <body>
    <HeaderPremium navItems={navItems} lang={lang} />

    <main>
      <slot />
    </main>

    <FooterPremium navItems={navItems} lang={lang} />

    <ScrollToTop />
  </body>
</html>