---
import BaseLayout from "../../layouts/BaseLayout.astro";
import HeroSection from "../../components/sections/HeroSection.astro";
import ServicesCarousel from "../../components/sections/ServicesCarousel.astro";
import ProductsGrid from "../../components/sections/ProductsGrid.astro";
import ContactSection from "../../components/sections/ContactSection.astro";
---

<BaseLayout
  title="Inicio"
  description="Software empresarial premium adaptado a tus necesidades."
  lang="es"
>
  <HeroSection
    id="inicio"
    title="Construimos software confiable para operaciones empresariales"
    subtitle="Ayudamos a empresas a mejorar sus operaciones con software a medida, integraciones, automatización y datos accionables."
    lang="es"
  />

  <ServicesCarousel id="funciones" lang="es" />

  <ProductsGrid
    id="productos"
    title="Nuestros Productos"
    description="Productos de software operativo diseñados para flujos reales de negocio."
    lang="es"
  />

  <ContactSection
    id="contacto"
    title="Hablemos de tu proyecto"
    description="Estamos listos para entender tus necesidades y evaluar cómo podemos ayudarte."
    lang="es"
  />
</BaseLayout>
