---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Container from "../../components/ui/Container.astro";
import Button from "../../components/ui/Button.astro";
import { products } from "../../data/products";

const positioning = [
  "Sistemas ya creados",
  "Plataformas personalizables",
  "Sistemas a medida",
  "Asesoría de software",
];

const operations = [
  {
    title: "Usar software ya creado",
    text: "Encontrar herramientas, plataformas y sistemas creados por Quantix para operaciones específicas de negocio.",
  },
  {
    title: "Adaptar una plataforma existente",
    text: "Ajustar una herramienta o plataforma de Quantix alrededor de los flujos, módulos y reglas de tu operación.",
  },
  {
    title: "Construir un sistema a medida",
    text: "Crear un sistema nuevo cuando la necesidad del negocio no encaja con una herramienta, plataforma o flujo existente.",
  },
  {
    title: "Definir el software antes de construir",
    text: "Ayudamos a las empresas a convertir ideas iniciales de software en requerimientos claros y estructurados, ya sea para continuar el desarrollo con Quantix o para tomar mejores decisiones internas.",
  },
];

const solutions = [
  "Sistemas de software operativo",
  "Plataformas SaaS",
  "Integraciones & APIs",
  "Reportería e inteligencia de negocio",
  "Automatización de procesos",
];

const workAreas = [
  "Operaciones de restaurantes",
  "Herramientas financieras",
  "Control de inventario",
  "Flujos de facturación",
  "Sistemas relacionados con POS",
  "Dashboards de reportería",
  "Herramientas de automatización",
];

const process = [
  {
    title: "Entender la operación",
    text: "Aclaramos flujos, restricciones, usuarios, datos y el resultado de negocio que el sistema debe apoyar.",
  },
  {
    title: "Diseñar el sistema",
    text: "Definimos la estructura del producto, integraciones, modelo de datos y ruta de implementación antes de construir.",
  },
  {
    title: "Construir e integrar",
    text: "Desarrollamos la plataforma, herramienta o automatización con uso real y mantenibilidad en mente.",
  },
  {
    title: "Acompañar la evolución",
    text: "Ayudamos a mejorar el sistema conforme cambian los requisitos, equipos y condiciones operativas.",
  },
];

const getProduct = (id: string) => {
  const product = products.find((item) => item.id === id);

  if (!product) {
    throw new Error(`Producto no encontrado: ${id}`);
  }

  return product;
};

const productProof = [
  {
    product: getProduct("takofy"),
    domain: "Plataforma SaaS de Quantix",
    railLabel: "Plataforma SaaS",
    proofLine:
      "Takofy es una plataforma SaaS de Quantix para operación de restaurantes, creada alrededor de comandas, mesas, pagos, cocina, reportería, inventario y ejecución offline-first.",
    areas: [
      {
        label: "Operación",
        items: ["Comandas", "Mesas", "Pagos"],
      },
      {
        label: "Cocina y stock",
        items: ["KDS", "Inventario", "Offline-first"],
      },
      {
        label: "Control",
        items: ["Reportería", "Flujos claros"],
      },
    ],
    visitLabel: "Visitar Takofy",
  },
  {
    product: getProduct("nica-finanzas"),
    domain: "Herramienta financiera gratuita",
    railLabel: "Herramienta gratuita",
    proofLine:
      "Nica Finanzas es una herramienta financiera gratuita creada por Quantix para Nicaragua, con calculadoras para salario, préstamos y liquidación laboral.",
    areas: [
      {
        label: "Cálculos",
        items: ["Salario", "Préstamos", "Liquidación"],
      },
      {
        label: "Parámetros locales",
        items: ["Nicaragua", "Entradas claras"],
      },
      {
        label: "Resultados",
        items: ["Salidas claras", "Utilidades prácticas"],
      },
    ],
    visitLabel: "Visitar Nica Finanzas",
  },
];
---

<BaseLayout
  title="Software listo, adaptable y a medida para operar tu empresa"
  description="Quantix Software ofrece herramientas ya creadas, plataformas personalizables, sistemas a medida y asesoría de software para empresas que necesitan flujos más claros, datos confiables y ejecución escalable."
  lang="es"
>
  <main class="home-page">
    <section class="home-hero" aria-labelledby="home-hero-title">
      <Container class="home-hero__container">
        <div class="home-hero__content">
          <p class="home-kicker">Quantix Software</p>
          <h1 id="home-hero-title">Software listo, adaptable y a medida para operar tu empresa</h1>
          <p class="home-hero__lead">
            Quantix Software ofrece herramientas ya creadas, plataformas personalizables, sistemas a medida y asesoría de software para empresas que necesitan flujos más claros, datos confiables y ejecución escalable.
          </p>
          <div class="home-actions">
            <Button href="/es/contacto/" variant="primary">Solicitar consulta</Button>
            <Button href="/es/soluciones/" variant="secondary">Explorar soluciones</Button>
          </div>
        </div>

        <div class="home-system-panel" aria-label="Command center conceptual de operaciones">
          <div class="command-center__header">
            <span>Command center operativo</span>
            <strong>Sistemas conectados</strong>
          </div>

          <div class="command-center__map">
            <div class="command-center__flow-line" aria-hidden="true"></div>

            <section class="command-layer command-layer--operation" aria-label="Capa de operación de negocio">
              <div class="command-layer__title">
                <span>Operación de negocio</span>
                <strong>Trabajo en movimiento</strong>
              </div>
              <div class="command-chips">
                <span>Flujos</span>
                <span>Equipos</span>
                <span>Aprobación</span>
              </div>
            </section>

            <section class="command-layer command-layer--systems" aria-label="Capa de sistemas">
              <div class="command-layer__title">
                <span>Capa de sistemas</span>
                <strong>Datos, integración y automatización</strong>
              </div>
              <div class="command-modules">
                <span>APIs</span>
                <span>Datos</span>
                <span>Automatización</span>
                <span>Reportería</span>
              </div>
            </section>

            <section class="command-layer command-layer--control" aria-label="Capa de control operativo">
              <div class="command-layer__title">
                <span>Control operativo</span>
                <strong>Visibilidad hacia ejecución</strong>
              </div>
              <div class="command-chips command-chips--control">
                <span>Visibilidad</span>
                <span>Decisiones</span>
                <span>Ejecución</span>
              </div>
            </section>

            <div class="command-center__rail" aria-hidden="true">
              <span>Operación</span>
              <span>Sistemas</span>
              <span>Control</span>
            </div>
          </div>
        </div>
      </Container>
    </section>

    <section class="positioning-strip" aria-label="Enfoques de Quantix Software">
      <Container>
        <ul>
          {positioning.map((item) => <li>{item}</li>)}
        </ul>
      </Container>
    </section>

    <section class="home-section" aria-labelledby="operations-title">
      <Container>
        <div class="section-heading section-heading--wide">
          <p class="section-eyebrow">Modelo comercial</p>
          <h2 id="operations-title">Cuatro formas en que Quantix ayuda a las empresas a avanzar</h2>
          <p>
            Desde herramientas existentes hasta sistemas a medida, Quantix ayuda a las empresas a elegir el camino correcto para su operación.
          </p>
        </div>

        <div class="editorial-grid editorial-grid--four">
          {operations.map((item) => (
            <article class="editorial-card">
              <h3>{item.title}</h3>
              <p>{item.text}</p>
            </article>
          ))}
        </div>
      </Container>
    </section>

    <section class="home-section home-section--surface" aria-labelledby="solutions-title">
      <Container>
        <div class="section-split">
          <div class="section-heading">
            <p class="section-eyebrow">Soluciones</p>
            <h2 id="solutions-title">Capacidades de software para operación, datos y ejecución</h2>
            <p>
              Diseñamos sistemas que conectan flujos operativos con los datos, integraciones y automatización necesarios para ejecutarlos con confianza.
            </p>
            <div class="home-actions">
              <Button href="/es/soluciones/" variant="secondary">Explorar soluciones</Button>
            </div>
          </div>

          <div class="capability-list">
            {solutions.map((item) => (
              <a href="/es/soluciones/" class="capability-item">
                <span>{item}</span>
              </a>
            ))}
          </div>
        </div>
      </Container>
    </section>

    <section class="home-section" aria-labelledby="products-title">
      <Container>
        <div class="section-heading section-heading--wide">
          <p class="section-eyebrow">Productos</p>
          <h2 id="products-title">Productos y herramientas creadas por Quantix</h2>
          <p>
            Quantix crea sus propias plataformas y herramientas para necesidades operativas específicas, desde ejecución de restaurantes hasta cálculos financieros para Nicaragua.
          </p>
        </div>

        <div class="product-proof-stack">
          {productProof.map((proof) => (
            <article class="product-proof-card">
              <div class="product-proof-card__content">
                <div class="product-proof-card__header">
                  <span class="product-status">{proof.product.status.es}</span>
                  <span class="product-domain">{proof.domain}</span>
                </div>
                <h3>{proof.product.title.es}</h3>
                <p>{proof.proofLine}</p>
                <div class="card-actions">
                  <Button href={proof.product.href.es} variant="secondary">Ver producto</Button>
                  {proof.product.publicUrl && (
                    <Button href={proof.product.publicUrl} target="_blank" variant="primary">
                      {proof.visitLabel}
                    </Button>
                  )}
                </div>
              </div>

              <div class="product-proof-map" aria-label={`Áreas del producto ${proof.product.title.es}`}>
                <div class="product-proof-map__rail">
                  <span>{proof.railLabel}</span>
                  <strong>{proof.product.title.es}</strong>
                </div>
                <div class="product-proof-map__areas">
                  {proof.areas.map((area) => (
                    <div class="product-proof-area">
                      <span>{area.label}</span>
                      <div>
                        {area.items.map((item) => <strong>{item}</strong>)}
                      </div>
                    </div>
                  ))}
                </div>
              </div>
            </article>
          ))}
        </div>
      </Container>
    </section>

    <section class="home-section home-section--surface" aria-labelledby="work-title">
      <Container>
        <div class="section-split section-split--reverse">
          <div class="work-panel">
            {workAreas.map((item) => <span>{item}</span>)}
          </div>

          <div class="section-heading">
            <p class="section-eyebrow">Experiencia</p>
            <h2 id="work-title">Experiencia en áreas de software operativo</h2>
            <p>
              Nuestro trabajo se organiza alrededor de los tipos de sistemas que las empresas necesitan para operar, controlar información y reducir trabajo repetitivo.
            </p>
            <div class="home-actions">
              <Button href="/es/trabajo/" variant="secondary">Ver áreas de trabajo</Button>
            </div>
          </div>
        </div>
      </Container>
    </section>

    <section class="home-section" aria-labelledby="process-title">
      <Container>
        <div class="section-heading section-heading--wide">
          <p class="section-eyebrow">Cómo trabajamos</p>
          <h2 id="process-title">Del contexto operativo al software en uso</h2>
        </div>

        <div class="process-grid">
          {process.map((step, index) => (
            <article class="process-card">
              <span>{String(index + 1).padStart(2, "0")}</span>
              <h3>{step.title}</h3>
              <p>{step.text}</p>
            </article>
          ))}
        </div>
      </Container>
    </section>

    <section class="home-section home-section--closing" aria-labelledby="closing-title">
      <Container>
        <div class="closing-panel">
          <div>
            <p class="section-eyebrow">Iniciar conversación</p>
            <h2 id="closing-title">Hablemos sobre tu proyecto de software</h2>
            <p>
              Trae el contexto operativo. Podemos ayudar a definir el sistema, integración o automatización que mejor encaja.
            </p>
          </div>
          <Button href="/es/contacto/" variant="primary">Contactar a Quantix</Button>
        </div>
      </Container>
    </section>
  </main>
</BaseLayout>

<style>
  .home-page {
    background: var(--bg);
    color: var(--text);
  }

  .home-hero {
    padding: clamp(8rem, 13vw, 10.5rem) 0 clamp(4rem, 7vw, 6rem);
    border-bottom: 1px solid var(--border);
    background:
      linear-gradient(180deg, color-mix(in srgb, var(--primary-soft) 24%, var(--bg)) 0%, var(--bg) 72%);
  }

  :global(.home-hero__container) {
    display: grid;
    grid-template-columns: minmax(0, 1.08fr) minmax(22rem, 0.92fr);
    gap: clamp(2rem, 5vw, 5rem);
    align-items: center;
  }

  .home-hero__content,
  .section-heading,
  .home-system-panel,
  .closing-panel > div {
    min-width: 0;
  }

  .home-kicker,
  .section-eyebrow {
    margin: 0 0 var(--space-4);
    color: var(--primary);
    font-size: var(--text-sm);
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .home-hero h1 {
    max-width: 50rem;
    margin: 0;
    color: var(--text);
    font-size: clamp(2.45rem, 5.2vw, 4.1rem);
    font-weight: 780;
    line-height: 1.03;
    letter-spacing: -0.018em;
    text-wrap: balance;
    overflow-wrap: break-word;
  }

  .home-hero__lead {
    max-width: 46rem;
    margin: var(--space-6) 0 0;
    color: var(--text-muted);
    font-size: clamp(1.05rem, 2vw, 1.28rem);
    line-height: 1.72;
  }

  .home-actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    margin-top: var(--space-8);
  }

  .home-system-panel {
    position: relative;
    overflow: hidden;
    min-height: 31rem;
    padding: clamp(1.1rem, 2.6vw, 1.55rem);
    border: 1px solid color-mix(in srgb, var(--primary) 14%, var(--border));
    border-radius: var(--radius-lg);
    background:
      linear-gradient(145deg, color-mix(in srgb, var(--surface) 93%, var(--primary-soft)), var(--surface));
    box-shadow: var(--shadow-lg);
  }

  .home-system-panel::before {
    content: "";
    position: absolute;
    inset: 3.65rem -18% auto;
    height: 1px;
    background: linear-gradient(90deg, transparent, color-mix(in srgb, var(--primary) 24%, transparent), transparent);
  }

  .home-system-panel::after {
    content: "";
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(color-mix(in srgb, var(--border) 42%, transparent) 1px, transparent 1px),
      linear-gradient(90deg, color-mix(in srgb, var(--border) 42%, transparent) 1px, transparent 1px);
    background-size: 2rem 2rem;
    opacity: 0.32;
    pointer-events: none;
  }

  .command-center__header,
  .command-center__map {
    position: relative;
    z-index: 1;
  }

  .command-center__header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: var(--space-4);
    color: var(--text-muted);
    font-size: var(--text-sm);
  }

  .command-center__header span {
    font-weight: 700;
  }

  .command-center__header strong {
    color: var(--text);
    font-weight: 800;
  }

  .command-center__map {
    display: grid;
    gap: var(--space-3);
    margin-top: var(--space-6);
    padding-left: 1.35rem;
  }

  .command-center__flow-line {
    position: absolute;
    top: 0.85rem;
    bottom: 2.65rem;
    left: 0.32rem;
    width: 1px;
    background: linear-gradient(180deg, color-mix(in srgb, var(--primary) 34%, transparent), color-mix(in srgb, var(--accent) 28%, transparent), color-mix(in srgb, var(--primary) 22%, transparent));
  }

  .command-layer {
    position: relative;
    padding: clamp(0.95rem, 2.2vw, 1.2rem);
    border: 1px solid color-mix(in srgb, var(--primary) 10%, var(--border));
    border-radius: var(--radius-md);
    background: color-mix(in srgb, var(--surface) 92%, white);
    box-shadow: var(--shadow-sm);
  }

  .command-layer--operation,
  .command-layer--control {
    display: grid;
    grid-template-columns: minmax(0, 0.78fr) minmax(0, 1.22fr);
    gap: var(--space-4);
    align-items: center;
  }

  .command-layer::before {
    content: "";
    position: absolute;
    top: 1.3rem;
    left: -1.55rem;
    width: 0.55rem;
    height: 0.55rem;
    border: 2px solid var(--surface);
    border-radius: var(--radius-full);
    background: var(--primary);
    box-shadow: 0 0 0 1px color-mix(in srgb, var(--primary) 30%, transparent);
  }

  .command-layer--systems {
    border-color: color-mix(in srgb, var(--accent) 20%, var(--border));
    background: color-mix(in srgb, var(--accent-soft) 26%, var(--surface));
  }

  .command-layer--systems::before {
    background: var(--accent);
    box-shadow: 0 0 0 1px color-mix(in srgb, var(--accent) 30%, transparent);
  }

  .command-layer--control {
    border-color: color-mix(in srgb, var(--primary) 20%, var(--border));
    background: color-mix(in srgb, var(--primary-soft) 34%, var(--surface));
  }

  .command-layer__title span {
    display: block;
    color: var(--text-muted);
    font-size: var(--text-xs);
    font-weight: 800;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .command-layer__title strong {
    display: block;
    margin-top: var(--space-1);
    color: var(--text);
    font-size: clamp(1rem, 2vw, 1.18rem);
    line-height: 1.25;
  }

  .command-chips,
  .command-modules,
  .command-center__rail {
    display: grid;
    gap: var(--space-2);
    margin-top: var(--space-4);
  }

  .command-chips {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .command-layer--operation .command-chips,
  .command-layer--control .command-chips {
    margin-top: 0;
  }

  .command-modules {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .command-chips span,
  .command-modules span,
  .command-center__rail span {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2.3rem;
    padding: 0.45rem 0.35rem;
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    background: color-mix(in srgb, var(--surface) 86%, transparent);
    color: var(--text-muted);
    font-size: var(--text-xs);
    font-weight: 800;
    line-height: 1.2;
    text-align: center;
  }

  .command-chips span {
    font-size: 0.7rem;
  }

  .command-modules span {
    background: color-mix(in srgb, var(--surface) 86%, var(--accent-soft));
    color: var(--text);
  }

  .command-chips--control span {
    color: var(--primary);
    background: color-mix(in srgb, var(--primary-soft) 42%, var(--surface));
  }

  .command-center__rail {
    grid-template-columns: repeat(3, minmax(0, 1fr));
    padding-top: var(--space-2);
    border-top: 1px solid color-mix(in srgb, var(--primary) 10%, var(--border));
  }

  .command-center__rail span {
    min-height: 2rem;
    background: var(--surface-2);
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .positioning-strip {
    padding: var(--space-4) 0;
    border-bottom: 1px solid var(--border);
    background: var(--surface);
  }

  .positioning-strip ul {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    justify-content: center;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .positioning-strip li {
    padding: 0.5rem 0.8rem;
    border: 1px solid var(--border);
    border-radius: var(--radius-full);
    color: var(--text-muted);
    font-size: var(--text-sm);
    font-weight: 700;
    background: var(--surface-2);
  }

  .home-section {
    padding: clamp(4rem, 7vw, 6.5rem) 0;
  }

  .home-section--surface {
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    background: var(--surface-2);
  }

  .section-heading {
    max-width: 42rem;
  }

  .section-heading--wide {
    max-width: 58rem;
    margin-bottom: var(--space-10);
  }

  .section-heading h2,
  .closing-panel h2 {
    margin: 0;
    color: var(--text);
    font-size: clamp(2rem, 4.4vw, 3.35rem);
    font-weight: 800;
    line-height: 1.08;
    letter-spacing: -0.018em;
    text-wrap: balance;
  }

  .section-heading p,
  .closing-panel p {
    margin: var(--space-4) 0 0;
    color: var(--text-muted);
    font-size: var(--text-lg);
    line-height: 1.7;
  }

  .editorial-grid,
  .process-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--space-5);
  }

  .editorial-grid--four {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .editorial-card,
  .process-card {
    min-height: 100%;
    padding: clamp(1.35rem, 3vw, 1.75rem);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    background: var(--surface);
    box-shadow: var(--shadow-sm);
  }

  .editorial-card h3,
  .process-card h3 {
    margin: 0 0 var(--space-3);
    font-size: var(--text-xl);
    line-height: 1.25;
  }

  .editorial-card p,
  .process-card p {
    margin: 0;
    color: var(--text-muted);
    line-height: 1.66;
  }

  .section-split {
    display: grid;
    grid-template-columns: minmax(0, 0.92fr) minmax(0, 1.08fr);
    gap: clamp(2rem, 5vw, 5rem);
    align-items: start;
  }

  .section-split--reverse {
    grid-template-columns: minmax(0, 1.08fr) minmax(0, 0.92fr);
  }

  .capability-list {
    display: grid;
    gap: var(--space-3);
  }

  .capability-item {
    display: flex;
    align-items: center;
    min-height: 4.4rem;
    padding: 0 var(--space-5);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    background: var(--surface);
    color: var(--text);
    font-weight: 800;
    text-decoration: none;
    box-shadow: var(--shadow-sm);
    transition: border-color 0.2s ease, color 0.2s ease, background-color 0.2s ease;
  }

  .capability-item:hover {
