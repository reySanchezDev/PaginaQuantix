---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import CommunityToolsGrid from "../../../components/sections/CommunityToolsGrid.astro";
---

<BaseLayout
  title="Recursos Propios & Comunidad"
  description="Herramientas y utilidades gratuitas para potenciar el flujo de trabajo."
  lang="es"
  isHeaderTransparent={false}
>
  <div class="community-page">
    <CommunityToolsGrid id="herramientas" lang="es" />
  </div>
</BaseLayout>

<style>
  .community-page {
    padding-top: clamp(76px, 18vw, 100px);
    min-height: 100vh;
    background: radial-gradient(circle at top right, var(--primary-soft) 0%, var(--bg) 40%);
  }
</style>
