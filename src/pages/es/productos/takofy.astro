---
import ProductLayout from "../../../layouts/ProductLayout.astro";
import HeroSection from "../../../components/sections/HeroSection.astro";
import CapabilitiesGrid from "../../../components/sections/CapabilitiesGrid.astro";

import ContactSection from "../../../components/sections/ContactSection.astro";
import Container from "../../../components/ui/Container.astro";
import Card from "../../../components/ui/Card.astro";
import Button from "../../../components/ui/Button.astro";
---

<ProductLayout
  title="Takofy - Gestión de Restaurantes"
  description="Software de gestión para restaurantes diseñado para operación rápida, offline-first, comandas, mesas, pagos, reportes y flujos de cocina."
  lang="es"
>
  <HeroSection
    id="hero"
    title="Takofy Gestión de Restaurantes"
    subtitle="Software de gestión para restaurantes diseñado para operación rápida, offline-first, comandas, mesas, pagos, reportes y flujos de cocina."
    lang="es"
    primaryCtaHref="https://takofy.app/es/"
    primaryCtaLabel="Visitar sitio web"
    primaryCtaTarget="_blank"
    secondaryCtaHref="/es/productos/"
    secondaryCtaLabel="Ver productos"
  />

  <section class="section-padding">
    <Container>
      <div class="text-center mb-12">
        <h2>Visión general</h2>
        <p class="text-muted max-w-2xl mx-auto">
          Takofy ayuda a equipos de restaurantes a mantener la operación en movimiento con flujos offline-first para comandas, mesas, pagos, reportes, cocina e inventario.
        </p>
      </div>

      <div class="visual-placeholder large">
        <span>Software publicado para gestión de restaurantes</span>
      </div>
    </Container>
  </section>

  <CapabilitiesGrid
    id="features"
    title="Características principales"
    description="Herramientas potentes para decisiones inteligentes."
    lang="es"
  />

  <section id="pricing" class="section-padding bg-surface-2">
    <Container>
      <div class="text-center mb-12">
        <h2>Empaquetado comercial</h2>
        <p class="text-muted">Visita el sitio público para conocer detalles y disponibilidad del producto.</p>
      </div>

      <div class="pricing-grid">
        <Card class="pricing-card">
          <div class="p-6">
            <h3 class="text-xl font-bold mb-2">Operación de restaurantes</h3>
            <div class="price mb-4">Sitio público</div>
            <ul class="features-list">
              <li>Flujos de comandas offline-first</li>
              <li>Mesas y pagos</li>
              <li>Reportes operativos</li>
            </ul>
            <Button href="https://takofy.app/es/" target="_blank" variant="secondary" class="w-full mt-6">Visitar sitio web</Button>
          </div>
        </Card>

        <Card class="pricing-card border-primary">
          <div class="p-6">
            <div class="badge-featured">Recomendado</div>
            <h3 class="text-xl font-bold mb-2">Cocina e inventario</h3>
            <div class="price mb-4">Sitio público</div>
            <ul class="features-list">
              <li>Flujos de cocina KDS</li>
              <li>Control de inventario</li>
              <li>Analítica para restaurantes</li>
            </ul>
            <Button href="https://takofy.app/es/" target="_blank" variant="primary" class="w-full mt-6">Visitar sitio web</Button>
          </div>
        </Card>
      </div>
    </Container>
  </section>

  <ContactSection
    id="contacto"
    title="¿Necesitas más información?"
    description="Visita el sitio de Takofy o contáctanos para conversar sobre software para operaciones de restaurantes."
    lang="es"
  />
</ProductLayout>

<style>
  .section-padding {
    padding: var(--space-12) 0;
  }
  .text-center {
    text-align: center;
  }
  .mb-12 {
    margin-bottom: var(--space-12);
  }
  .text-muted {
    color: var(--text-muted);
  }
  .max-w-2xl {
    max-width: 42rem;
  }
  .mx-auto {
    margin-left: auto;
    margin-right: auto;
  }
  .bg-surface-2 {
    background-color: var(--surface-2);
  }
  .w-full {
    width: 100%;
  }
  .mt-6 {
    margin-top: var(--space-6);
  }
  .p-6 {
    padding: var(--space-6);
  }

  .visual-placeholder {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    aspect-ratio: 16/9;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--text-muted);
  }

  .pricing-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-8);
    max-width: 800px;
    margin: 0 auto;
  }

  @media (min-width: 768px) {
    .pricing-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  .price {
    font-size: var(--text-3xl);
    font-weight: 700;
    color: var(--text);
  }

  .features-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    color: var(--text-muted);
  }

  .border-primary {
    border-color: var(--primary);
    box-shadow: var(--shadow-lg);
  }

  .badge-featured {
    background: var(--primary);
    color: white;
    font-size: var(--text-xs);
    padding: 4px 8px;
    border-radius: var(--radius-full);
    display: inline-block;
    margin-bottom: var(--space-2);
  }
</style>
