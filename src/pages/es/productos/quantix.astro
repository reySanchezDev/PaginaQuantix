---
import ProductLayout from "../../../layouts/ProductLayout.astro";
import HeroSection from "../../../components/sections/HeroSection.astro";
import CapabilitiesGrid from "../../../components/sections/CapabilitiesGrid.astro";

import ContactSection from "../../../components/sections/ContactSection.astro";
import Container from "../../../components/ui/Container.astro";
import Card from "../../../components/ui/Card.astro";
import Button from "../../../components/ui/Button.astro";
---

<ProductLayout
  title="Quantix - Plataforma Operacional"
  description="Plataforma operacional para inventario, facturación, reportes y control de negocio."
  lang="es"
>
  <HeroSection
    id="hero"
    title="Quantix Plataforma Operacional"
    subtitle="Control total sobre tus operaciones, finanzas y recursos en una sola plataforma unificada."
    lang="es"
  />

  <section class="section-padding">
    <Container>
      <div class="text-center mb-12">
        <h2>Visión general</h2>
        <p class="text-muted max-w-2xl mx-auto">
          Quantix se está desarrollando como una plataforma operacional para inventario, facturación, caja, reportes y control de permisos.
        </p>
        <p class="availability-note max-w-2xl mx-auto">
          Este producto se encuentra actualmente en desarrollo privado y aún no está disponible públicamente.
        </p>
      </div>

      <div class="visual-placeholder large">
        <span>Vista previa del producto en desarrollo</span>
      </div>
    </Container>
  </section>

  <CapabilitiesGrid
    id="features"
    title="Características principales"
    description="Herramientas potentes para decisiones inteligentes."
    lang="es"
  />

  <section id="pricing" class="section-padding bg-surface-2">
    <Container>
      <div class="text-center mb-12">
        <h2>Empaquetado comercial</h2>
        <p class="text-muted">Los paquetes de implementación se definirán según las necesidades operativas cuando el producto esté listo para iniciativas seleccionadas.</p>
      </div>

      <div class="pricing-grid">
        <Card class="pricing-card">
          <div class="p-6">
            <h3 class="text-xl font-bold mb-2">Piloto operacional</h3>
            <div class="price mb-4">Requiere alcance</div>
            <ul class="features-list">
              <li>Flujos base de inventario y facturación</li>
              <li>Roles de usuario y permisos</li>
              <li>Soporte de implementación</li>
            </ul>
            <Button href="#contacto" variant="secondary" class="w-full mt-6">Solicitar información</Button>
          </div>
        </Card>

        <Card class="pricing-card border-primary">
          <div class="p-6">
            <div class="badge-featured">Recomendado</div>
            <h3 class="text-xl font-bold mb-2">Implementación a medida</h3>
            <div class="price mb-4">A medida</div>
            <ul class="features-list">
              <li>Módulos operativos avanzados</li>
              <li>Reportes e integraciones</li>
              <li>Modelo de soporte definido por alcance</li>
            </ul>
            <Button href="#contacto" variant="primary" class="w-full mt-6">Contactarnos</Button>
          </div>
        </Card>
      </div>
    </Container>
  </section>

  <ContactSection
    id="contacto"
    title="¿Necesitas más información?"
    description="Contáctanos para conversar sobre disponibilidad del producto y alcance de implementación."
    lang="es"
  />
</ProductLayout>

<style>
  .section-padding {
    padding: var(--space-12) 0;
  }
  .text-center {
    text-align: center;
  }
  .mb-12 {
    margin-bottom: var(--space-12);
  }
  .text-muted {
    color: var(--text-muted);
  }
  .availability-note {
    color: color-mix(in srgb, var(--text) 82%, var(--text-muted));
    font-size: var(--text-sm);
    line-height: 1.6;
    margin-top: var(--space-4);
    padding: 0.9rem 1rem;
    border: 1px solid color-mix(in srgb, var(--primary) 12%, var(--border));
    border-radius: var(--radius-md);
    background: color-mix(in srgb, var(--surface) 88%, var(--primary-soft));
  }
  .max-w-2xl {
    max-width: 42rem;
  }
  .mx-auto {
    margin-left: auto;
    margin-right: auto;
  }
  .bg-surface-2 {
    background-color: var(--surface-2);
  }
  .w-full {
    width: 100%;
  }
  .mt-6 {
    margin-top: var(--space-6);
  }
  .p-6 {
    padding: var(--space-6);
  }

  .visual-placeholder {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    aspect-ratio: 16/9;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--text-muted);
  }

  .pricing-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-8);
    max-width: 800px;
    margin: 0 auto;
  }

  @media (min-width: 768px) {
    .pricing-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  .price {
    font-size: var(--text-3xl);
    font-weight: 700;
    color: var(--text);
  }

  .features-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    color: var(--text-muted);
  }

  .border-primary {
    border-color: var(--primary);
    box-shadow: var(--shadow-lg);
  }

  .badge-featured {
    background: var(--primary);
    color: white;
    font-size: var(--text-xs);
    padding: 4px 8px;
    border-radius: var(--radius-full);
    display: inline-block;
    margin-bottom: var(--space-2);
  }
</style>
