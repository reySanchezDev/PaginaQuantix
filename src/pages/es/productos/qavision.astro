---
import ProductLayout from "../../../layouts/ProductLayout.astro";
import ContactSection from "../../../components/sections/ContactSection.astro";
import Container from "../../../components/ui/Container.astro";
import Button from "../../../components/ui/Button.astro";
import ReleaseHistory from "../../../components/sections/ReleaseHistory.astro";
import { qavisionTool } from "../../../data/qavisionTool";
---

<ProductLayout
  title="QAVision — Herramienta gratuita de evidencia QA por Quantix"
  description="QAVision es una herramienta gratuita de evidencia QA creada por Quantix para captura visual, grabación por zona, anotaciones y evidencia organizada."
  lang="es"
>
  <section id="hero" class="product-hero">
    <Container>
      <div class="product-hero__grid">
        <div class="product-hero__content">
          <span class="product-kicker">Herramienta gratuita de evidencia QA creada por Quantix</span>
          <h1>QAVision</h1>
          <p>{qavisionTool.description.es}</p>
          <div class="hero-actions-local">
            <Button href={qavisionTool.downloadUrl} target="_blank" variant="primary">Descargar QAVision</Button>
            <Button href="/es/productos/" variant="secondary">Ver productos</Button>
          </div>
        </div>

        <div class="hero-tool-panel" aria-label="Detalles del producto QAVision">
          <div class="tool-panel__header">
            <span>Versión actual</span>
            <strong>v{qavisionTool.version}</strong>
          </div>
          <div class="tool-panel__meta">
            <div>
              <span>Tipo de instalador</span>
              <strong>{qavisionTool.type}</strong>
            </div>
            <div>
              <span>Tipo de producto</span>
              <strong>Herramienta gratuita de evidencia QA</strong>
            </div>
          </div>
          <div class="tool-panel__tags">
            {qavisionTool.tags.map((tag) => <span>{tag}</span>)}
          </div>
        </div>
      </div>
    </Container>
  </section>

  <section class="section-padding">
    <Container>
      <div class="text-center mb-12">
        <h2>Capacidades actuales</h2>
        <p class="text-muted max-w-2xl mx-auto">
          QAVision se enfoca en captura de evidencia visual, contexto QA organizado y flujos de revisión más completos para Windows.
        </p>
      </div>

      <div class="feature-grid">
        {qavisionTool.features.es.map((feature) => (
          <article>
            <span>QAVision</span>
            <p>{feature}</p>
          </article>
        ))}
      </div>
    </Container>
  </section>

  <ReleaseHistory lang="es" />

  <ContactSection
    id="contact"
    title="¿Necesitas un flujo de evidencia QA?"
    description="Descarga QAVision o contacta a Quantix para conversar sobre evidencia QA, flujos de software y herramientas operativas."
    lang="es"
  />
</ProductLayout>

<style>
  .section-padding { padding: var(--space-12) 0; }
  .text-center { text-align: center; }
  .mb-12 { margin-bottom: var(--space-12); }
  .text-muted { color: var(--text-muted); }
  .max-w-2xl { max-width: 42rem; }
  .mx-auto { margin-left: auto; margin-right: auto; }
  .bg-surface-2 { background-color: var(--surface-2); }

  .product-hero {
    padding: clamp(8rem, 14vw, 10rem) 0 clamp(4rem, 7vw, 5.5rem);
    border-bottom: 1px solid var(--border);
    background: linear-gradient(180deg, color-mix(in srgb, var(--primary-soft) 34%, var(--bg)) 0%, var(--bg) 86%);
  }

  .product-hero__grid {
    display: grid;
    grid-template-columns: minmax(0, 0.95fr) minmax(21rem, 1.05fr);
    gap: clamp(2rem, 5vw, 4.5rem);
    align-items: center;
  }

  .product-hero__content {
    min-width: 0;
  }

  .product-kicker {
    display: inline-flex;
    margin-bottom: var(--space-4);
    color: var(--primary);
    font-size: var(--text-xs);
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .product-hero h1 {
    max-width: 44rem;
    margin: 0;
    color: var(--text);
    font-size: clamp(2.45rem, 5.5vw, 4.45rem);
    line-height: 1.03;
    letter-spacing: -0.02em;
  }

  .product-hero p {
    max-width: 42rem;
    margin: var(--space-5) 0 0;
    color: var(--text-muted);
    font-size: clamp(1.03rem, 2vw, 1.22rem);
    line-height: 1.65;
  }

  .hero-actions-local {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    margin-top: var(--space-8);
  }

  .hero-tool-panel {
    display: grid;
    gap: var(--space-4);
    padding: clamp(1.25rem, 4vw, 2rem);
    border: 1px solid color-mix(in srgb, var(--primary) 16%, var(--border));
    border-radius: var(--radius-lg);
    background:
      linear-gradient(color-mix(in srgb, var(--border) 42%, transparent) 1px, transparent 1px),
      linear-gradient(90deg, color-mix(in srgb, var(--border) 42%, transparent) 1px, transparent 1px),
      var(--surface);
    background-size: 2.5rem 2.5rem;
    box-shadow: var(--shadow-sm);
  }

  .tool-panel__header,
  .tool-panel__meta > div {
    padding: var(--space-5);
    border: 1px solid color-mix(in srgb, var(--primary) 14%, var(--border));
    border-radius: var(--radius-md);
    background: color-mix(in srgb, var(--surface) 88%, var(--primary-soft));
  }

  .tool-panel__header span,
  .tool-panel__meta span {
    display: block;
    color: var(--text-muted);
    font-size: var(--text-xs);
    font-weight: 800;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .tool-panel__header strong,
  .tool-panel__meta strong {
    display: block;
    margin-top: var(--space-2);
    color: var(--text);
    font-size: clamp(1.2rem, 3vw, 1.75rem);
    line-height: 1.15;
  }

  .tool-panel__meta {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--space-3);
  }

  .tool-panel__tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .tool-panel__tags span {
    padding: 0.45rem 0.65rem;
    border: 1px solid var(--border);
    border-radius: var(--radius-full);
    background: var(--surface);
    color: var(--text-muted);
    font-size: var(--text-xs);
    font-weight: 800;
  }

  .feature-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--space-5);
  }

  .feature-grid article {
    padding: clamp(1.25rem, 3vw, 1.65rem);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    background: var(--surface);
    box-shadow: var(--shadow-sm);
  }

  .feature-grid span {
    display: block;
    margin-bottom: var(--space-3);
    color: var(--primary);
    font-size: var(--text-xs);
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .feature-grid p {
    margin: 0;
    color: var(--text-muted);
    line-height: 1.65;
  }

  @media (max-width: 980px) {
    .product-hero__grid,
    .feature-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 767px) {
    .product-hero {
      padding-top: 7rem;
    }

    .product-hero__grid,
    .product-hero__content,
    .product-hero p,
    .hero-actions-local,
    .hero-tool-panel,
    .feature-grid {
      max-width: 22.5rem;
    }

    .product-hero h1 {
      font-size: clamp(2rem, 8vw, 2.55rem);
      line-height: 1.08;
    }

    .hero-actions-local {
      flex-direction: column;
      align-items: stretch;
    }

    .hero-actions-local :global(.btn) {
      width: 100%;
    }

    .tool-panel__meta {
      grid-template-columns: 1fr;
    }

    .text-center {
      text-align: left;
    }

    .max-w-2xl {
      max-width: 22.5rem;
      margin-left: 0;
      margin-right: 0;
    }
  }
</style>
