---
import ProductLayout from "../../../layouts/ProductLayout.astro";
import HeroSection from "../../../components/sections/HeroSection.astro";

import ContactSection from "../../../components/sections/ContactSection.astro";
import Container from "../../../components/ui/Container.astro";
import Card from "../../../components/ui/Card.astro";
import Button from "../../../components/ui/Button.astro";
---

<ProductLayout
  title="Nica Finanzas - Calculadoras Financieras para Nicaragua"
  description="Calculadoras financieras para Nicaragua, incluyendo salario, préstamos y liquidación laboral."
  lang="es"
>
  <HeroSection
    id="hero"
    title="Nica Finanzas"
    subtitle="Calculadoras financieras para Nicaragua, incluyendo salario, préstamos y liquidación laboral."
    lang="es"
    primaryCtaHref="https://nicafinanzas.com/"
    primaryCtaLabel="Visitar sitio web"
    primaryCtaTarget="_blank"
  />

  <section class="section-padding">
    <Container>
      <div class="text-center mb-12">
        <h2>Calculadoras financieras para Nicaragua</h2>
        <p class="text-muted max-w-2xl mx-auto">
          Nica Finanzas ofrece calculadoras prácticas para escenarios de salario, préstamos y liquidación laboral en Nicaragua.
        </p>
      </div>

      <div class="visual-placeholder large">
        <span>Calculadoras financieras publicadas para Nicaragua</span>
      </div>
    </Container>
  </section>

  <section id="pricing" class="section-padding bg-surface-2">
    <Container>
      <div class="text-center mb-12">
        <h2>Disponibilidad del producto</h2>
        <p class="text-muted">Visita el sitio público para conocer detalles y disponibilidad del producto.</p>
      </div>

      <div class="pricing-grid">
        <Card class="pricing-card">
          <div class="p-6">
            <h3 class="text-xl font-bold mb-2">Calculadora salarial</h3>
            <div class="price mb-4">Sitio público</div>
            <ul class="features-list">
              <li>Cálculos de salario</li>
              <li>Parámetros para Nicaragua</li>
              <li>Resultados claros</li>
            </ul>
            <Button href="https://nicafinanzas.com/" target="_blank" variant="secondary" class="w-full mt-6">Visitar sitio web</Button>
          </div>
        </Card>

        <Card class="pricing-card border-primary">
          <div class="p-6">
            <h3 class="text-xl font-bold mb-2">Préstamos y liquidación</h3>
            <div class="price mb-4">Sitio público</div>
            <ul class="features-list">
              <li>Cálculos de préstamos</li>
              <li>Liquidación laboral</li>
              <li>Herramientas de referencia para usuarios locales</li>
            </ul>
            <Button href="https://nicafinanzas.com/" target="_blank" variant="primary" class="w-full mt-6">Visitar sitio web</Button>
          </div>
        </Card>
      </div>
    </Container>
  </section>

  <ContactSection
    id="contacto"
    title="¿Necesitas más información?"
    description="Visita el sitio de Nica Finanzas o contáctanos para conversar sobre herramientas financieras para Nicaragua."
    lang="es"
  />
</ProductLayout>

<style>
  .section-padding {
    padding: var(--space-12) 0;
  }
  .text-center {
    text-align: center;
  }
  .mb-12 {
    margin-bottom: var(--space-12);
  }
  .text-muted {
    color: var(--text-muted);
  }
  .max-w-2xl {
    max-width: 42rem;
  }
  .mx-auto {
    margin-left: auto;
    margin-right: auto;
  }
  .bg-surface-2 {
    background-color: var(--surface-2);
  }
  .w-full {
    width: 100%;
  }
  .mt-6 {
    margin-top: var(--space-6);
  }
  .p-6 {
    padding: var(--space-6);
  }

  .visual-placeholder {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    aspect-ratio: 16/9;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--text-muted);
  }

  .pricing-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-8);
    max-width: 800px;
    margin: 0 auto;
  }

  @media (min-width: 768px) {
    .pricing-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  .price {
    font-size: var(--text-3xl);
    font-weight: 700;
    color: var(--text);
  }

  .features-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    color: var(--text-muted);
  }

  .border-primary {
    border-color: var(--primary);
    box-shadow: var(--shadow-lg);
  }
</style>
