---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Container from "../../../components/ui/Container.astro";
import Button from "../../../components/ui/Button.astro";

const principles = [
  {
    title: "Ingeniería con mentalidad de producción",
    text: "Tratamos el software como algo que debe seguir funcionando después del lanzamiento: mantenible, observable y claro para operar.",
  },
  {
    title: "Comprensión operativa",
    text: "Nos enfocamos en flujos de negocio como inventario, facturación, reportería, herramientas internas, integraciones y automatización.",
  },
  {
    title: "Estrategia técnica práctica",
    text: "Valoramos decisiones que reducen riesgo, ordenan el alcance y crean sistemas capaces de evolucionar con el negocio.",
  },
];
---

<BaseLayout
  title="Nosotros"
  description="Quantix Software construye sistemas confiables para empresas que necesitan control operativo, claridad de datos y procesos digitales escalables."
  lang="es"
  isHeaderTransparent={false}
>
  <div class="page-shell">
    <section class="page-hero">
      <Container>
        <div class="page-hero__content">
          <span class="page-kicker">Nosotros</span>
          <h1 class="page-title">Sistemas confiables para empresas que operan en el mundo real</h1>
          <p class="page-lead">
            Quantix Software construye sistemas confiables para empresas que necesitan control operativo, claridad de datos y procesos digitales escalables.
          </p>
          <div class="page-actions">
            <Button href="/es/soluciones/" variant="secondary" size="lg">Explorar soluciones</Button>
            <Button href="/es/contacto/" variant="glow" size="lg">Solicitar consulta</Button>
          </div>
        </div>
      </Container>
    </section>

    <section class="page-section">
      <Container>
        <div class="section-heading">
          <h2>Construimos sistemas, no solo pantallas</h2>
          <p>
            Nos importa la capa operativa detrás de la interfaz: modelos de datos, integraciones, permisos, reportería, despliegue y flujos que las personas usan todos los días.
          </p>
        </div>

        <div class="content-grid content-grid--3">
          {principles.map((principle) => (
            <article class="content-card">
              <h3>{principle.title}</h3>
              <p>{principle.text}</p>
            </article>
          ))}
        </div>
      </Container>
    </section>

    <section class="page-section page-section--surface">
      <Container>
        <div class="page-cta-band">
          <h2>Software para empresas que necesitan control y claridad</h2>
          <p>
            Quantix Software está orientada a empresas que necesitan sistemas confiables, no experimentos de corta vida ni sitios genéricos.
          </p>
          <div class="page-actions">
            <Button href="/es/trabajo/" variant="secondary">Ver áreas de experiencia</Button>
            <Button href="/es/contacto/" variant="glow">Iniciar conversación</Button>
          </div>
        </div>
      </Container>
    </section>
  </div>
</BaseLayout>
