---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Container from "../../../components/ui/Container.astro";
import Button from "../../../components/ui/Button.astro";
import ContactSection from "../../../components/sections/ContactSection.astro";

const projectTypes = [
  "Operational software systems",
  "SaaS platforms",
  "Internal business tools",
  "Integrations and APIs",
  "Reporting and BI dashboards",
  "Inventory and billing workflows",
  "Process automation",
  "Legacy system modernization",
];
---

<BaseLayout
  title="Contact"
  description="Contact Quantix Software to discuss custom software, SaaS platforms, internal tools, integrations, reporting, automation and operational systems."
  lang="en"
  isHeaderTransparent={false}
>
  <div class="page-shell">
    <section class="page-hero">
      <Container>
        <div class="page-hero__content">
          <span class="page-kicker">Contact</span>
          <h1 class="page-title">Book a consultation for your software project</h1>
          <p class="page-lead">
            Tell us what you are building, improving, integrating, or trying to automate. We will help clarify the next practical step.
          </p>
          <div class="page-actions">
            <Button href="mailto:contact@quantix.software" variant="glow" size="lg">Book a consultation</Button>
            <Button href="https://wa.me/50585213462" target="_blank" variant="secondary" size="lg">WhatsApp</Button>
          </div>
        </div>
      </Container>
    </section>

    <section class="page-section">
      <Container>
        <div class="split-layout">
          <div class="section-heading">
            <h2>Project types we can discuss</h2>
            <p>
              A good first conversation is about scope, constraints, business context, and what needs to become more reliable.
            </p>
          </div>

          <div class="content-card">
            <h3>Relevant project areas</h3>
            <ul>
              {projectTypes.map((type) => <li>{type}</li>)}
            </ul>
          </div>
        </div>
      </Container>
    </section>

    <ContactSection
      id="direct-contact"
      title="Direct contact channels"
      description="Use email or WhatsApp to start a clear conversation about your project."
      lang="en"
    />
  </div>
</BaseLayout>
