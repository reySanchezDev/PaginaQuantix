---
import BaseLayout from "../../layouts/BaseLayout.astro";
import HeroSection from "../../components/sections/HeroSection.astro";
import ServicesCarousel from "../../components/sections/ServicesCarousel.astro";
import ProductsGrid from "../../components/sections/ProductsGrid.astro";
import TrustSection from "../../components/sections/TrustSection.astro";
import ContactSection from "../../components/sections/ContactSection.astro";
---

<BaseLayout
  title="Home"
  description="Premium enterprise management software tailored to your needs."
  lang="en"
>
  <HeroSection
    id="home"
    title="Transforming your companys digital future"
    subtitle="We drive business efficiency with tailored technological solutions. Strategy, innovation, and tangible results for the digital era."
    lang="en"
  />

  <ServicesCarousel id="features" lang="en" />

  <ProductsGrid
    id="products"
    title="Our Products"
    description="Specific solutions designed for complex problems."
    lang="en"
  />

  {
    /* <TrustSection
    title="Companies that trust us"
  /> */
  }

  <ContactSection
    id="contact"
    title="Lets talk about your project"
    description="We are ready to take your company to the next level. Contact us today."
    lang="en"
  />
</BaseLayout>