---
import BaseLayout from "../../layouts/BaseLayout.astro";
import HeroSection from "../../components/sections/HeroSection.astro";
import ServicesCarousel from "../../components/sections/ServicesCarousel.astro";
import ProductsGrid from "../../components/sections/ProductsGrid.astro";
import ContactSection from "../../components/sections/ContactSection.astro";
---

<BaseLayout
  title="Home"
  description="Premium enterprise management software tailored to your needs."
  lang="en"
>
  <HeroSection
    id="home"
    title="Building reliable software for business operations"
    subtitle="We help companies improve operations with tailored software, integrations, automation, and actionable data."
    lang="en"
  />

  <ServicesCarousel id="features" lang="en" />

  <ProductsGrid
    id="products"
    title="Our Products"
    description="Operational software products designed for real business workflows."
    lang="en"
  />

  <ContactSection
    id="contact"
    title="Let’s talk about your project"
    description="Tell us what you are building, improving, or trying to automate."
    lang="en"
  />
</BaseLayout>
