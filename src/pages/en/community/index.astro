---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import CommunityToolsGrid from "../../../components/sections/CommunityToolsGrid.astro";
---

<BaseLayout
  title="In-house Tools & Community"
  description="Free tools and utilities to empower your workflow."
  lang="en"
  isHeaderTransparent={false}
>
  <div class="community-page">
    <CommunityToolsGrid id="tools" lang="en" />
  </div>
</BaseLayout>

<style>
  .community-page {
    padding-top: clamp(76px, 18vw, 100px);
    min-height: 100vh;
    background: radial-gradient(circle at top right, var(--primary-soft) 0%, var(--bg) 40%);
  }
</style>
