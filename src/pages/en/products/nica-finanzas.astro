---
import ProductLayout from '../../../layouts/ProductLayout.astro';
import HeroSection from '../../../components/sections/HeroSection.astro';

import ContactSection from '../../../components/sections/ContactSection.astro';
import Container from '../../../components/ui/Container.astro';
import Card from '../../../components/ui/Card.astro';
import Button from '../../../components/ui/Button.astro';

---

<ProductLayout 
    title="Nica Finanzas - Financial Calculators for Nicaragua" 
    description="Financial calculators for Nicaragua, including salary, loan and employment settlement calculations."
    lang="en"
>
    <!-- Product Hero -->
    <HeroSection 
        id="hero"
        title="Nica Finanzas"
        subtitle="Financial calculators for Nicaragua, including salary, loan and employment settlement calculations."
        lang="en"
        primaryCtaHref="https://nicafinanzas.com/"
        primaryCtaLabel="Visit website"
        primaryCtaTarget="_blank"
    />

    <!-- Overview -->
    <section class="section-padding">
        <Container>
            <div class="text-center mb-12">
                <h2>Financial Calculators for Nicaragua</h2>
                <p class="text-muted max-w-2xl mx-auto">
                    Nica Finanzas provides practical calculators for salary, loan, and employment settlement scenarios in Nicaragua.
                </p>
            </div>
            
            <div class="visual-placeholder large">
               <span>Published financial calculators for Nicaragua</span>
            </div>
        </Container>
    </section>

    <!-- Pricing -->
    <section id="pricing" class="section-padding bg-surface-2">
        <Container>
            <div class="text-center mb-12">
                <h2>Product Availability</h2>
                <p class="text-muted">Visit the public website for product details and availability.</p>
            </div>
            
            <div class="pricing-grid">
                <Card class="pricing-card">
                    <div class="p-6">
                        <h3 class="text-xl font-bold mb-2">Salary Calculator</h3>
                        <div class="price mb-4">Public website</div>
                        <ul class="features-list">
                            <li>Salary calculations</li>
                            <li>Nicaragua-specific inputs</li>
                            <li>Clear calculation outputs</li>
                        </ul>
                        <Button href="https://nicafinanzas.com/" target="_blank" variant="secondary" class="w-full mt-6">Visit website</Button>
                    </div>
                </Card>
                
                <Card class="pricing-card border-primary">
                    <div class="p-6">
                        <h3 class="text-xl font-bold mb-2">Loan and Settlement Tools</h3>
                        <div class="price mb-4">Public website</div>
                        <ul class="features-list">
                            <li>Loan calculations</li>
                            <li>Employment settlement calculations</li>
                            <li>Reference tools for local users</li>
                        </ul>
                        <Button href="https://nicafinanzas.com/" target="_blank" variant="primary" class="w-full mt-6">Visit website</Button>
                    </div>
                </Card>
            </div>
        </Container>
    </section>

    <ContactSection
        id="contact"
        title="Need more information?"
        description="Visit the Nica Finanzas website or contact us to discuss financial calculator tools for Nicaragua."
        lang="en"
    />
</ProductLayout>

<style>
    .section-padding { padding: var(--space-12) 0; }
    .text-center { text-align: center; }
    .mb-12 { margin-bottom: var(--space-12); }
    .text-muted { color: var(--text-muted); }
    .max-w-2xl { max-width: 42rem; }
    .mx-auto { margin-left: auto; margin-right: auto; }
    .bg-surface-2 { background-color: var(--surface-2); }
    .w-full { width: 100%; }
    .mt-6 { margin-top: var(--space-6); }
    .p-6 { padding: var(--space-6); }
    
    .visual-placeholder {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--radius-lg);
        aspect-ratio: 16/9;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--text-muted);
    }
    
    .pricing-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: var(--space-8);
        max-width: 800px;
        margin: 0 auto;
    }
    
    @media (min-width: 768px) {
        .pricing-grid { grid-template-columns: 1fr 1fr; }
    }
    
    .price {
        font-size: var(--text-3xl);
        font-weight: 700;
        color: var(--text);
    }
    
    .features-list {
        list-style: none;
        padding: 0;
        margin: 0;
        display: flex;
        flex-direction: column;
        gap: var(--space-2);
        color: var(--text-muted);
    }
    
    .border-primary {
        border-color: var(--primary);
        box-shadow: var(--shadow-lg);
    }
</style>
