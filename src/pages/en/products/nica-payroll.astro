---
import ProductLayout from '../../../layouts/ProductLayout.astro';
import HeroSection from '../../../components/sections/HeroSection.astro';

import ContactSection from '../../../components/sections/ContactSection.astro';
import Container from '../../../components/ui/Container.astro';
import Card from '../../../components/ui/Card.astro';
import Button from '../../../components/ui/Button.astro';

---

<ProductLayout 
    title="Nica Payroll - Payroll & HR" 
    description="Regional payroll and HR software for Nicaraguan business operations."
    lang="en"
>
    <!-- Product Hero -->
    <HeroSection 
        id="hero"
        title="Nica Payroll"
        subtitle="A localized payroll and HR product designed for companies operating in Nicaragua."
        lang="en"
    />

    <!-- Overview -->
    <section class="section-padding">
        <Container>
            <div class="text-center mb-12">
                <h2>Localized Payroll Workflows</h2>
                <p class="text-muted max-w-2xl mx-auto">
                    Nica Payroll focuses on payroll calculations, vacation management, employee records, and reporting for local operations.
                </p>
                <p class="availability-note max-w-2xl mx-auto">
                    This product is currently in private beta and is not publicly available yet.
                </p>
            </div>
            
            <div class="visual-placeholder large">
               <span>Product preview in private beta</span>
            </div>
        </Container>
    </section>

    <!-- Pricing -->
    <section id="pricing" class="section-padding bg-surface-2">
        <Container>
            <div class="text-center mb-12">
                <h2>Private Beta Status</h2>
                <p class="text-muted">Commercial packages will be finalized after private beta validation.</p>
            </div>
            
            <div class="pricing-grid">
                <Card class="pricing-card">
                    <div class="p-6">
                        <h3 class="text-xl font-bold mb-2">Beta Information</h3>
                        <div class="price mb-4">Pricing in review</div>
                        <ul class="features-list">
                            <li>Up to 15 employees</li>
                            <li>Automatic calculations</li>
                            <li>Export to DGI</li>
                        </ul>
                        <Button href="#contact" variant="secondary" class="w-full mt-6">Request information</Button>
                    </div>
                </Card>
                
                <Card class="pricing-card border-primary">
                    <div class="p-6">
                        <h3 class="text-xl font-bold mb-2">Corporate</h3>
                        <div class="price mb-4">Custom</div>
                        <ul class="features-list">
                            <li>Unlimited employees</li>
                            <li>Employee portal</li>
                            <li>API integrations by scope</li>
                        </ul>
                        <Button href="#contact" variant="primary" class="w-full mt-6">Contact us</Button>
                    </div>
                </Card>
            </div>
        </Container>
    </section>

    <ContactSection
        id="contact"
        title="Need more information?"
        description="Contact us to discuss private beta availability and local payroll requirements."
        lang="en"
    />
</ProductLayout>

<style>
    .section-padding { padding: var(--space-12) 0; }
    .text-center { text-align: center; }
    .mb-12 { margin-bottom: var(--space-12); }
    .text-muted { color: var(--text-muted); }
    .availability-note {
        color: color-mix(in srgb, var(--text) 82%, var(--text-muted));
        font-size: var(--text-sm);
        line-height: 1.6;
        margin-top: var(--space-4);
        padding: 0.9rem 1rem;
        border: 1px solid color-mix(in srgb, var(--primary) 12%, var(--border));
        border-radius: var(--radius-md);
        background: color-mix(in srgb, var(--surface) 88%, var(--primary-soft));
    }
    .max-w-2xl { max-width: 42rem; }
    .mx-auto { margin-left: auto; margin-right: auto; }
    .bg-surface-2 { background-color: var(--surface-2); }
    .w-full { width: 100%; }
    .mt-6 { margin-top: var(--space-6); }
    .p-6 { padding: var(--space-6); }
    
    .visual-placeholder {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--radius-lg);
        aspect-ratio: 16/9;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--text-muted);
    }
    
    .pricing-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: var(--space-8);
        max-width: 800px;
        margin: 0 auto;
    }
    
    @media (min-width: 768px) {
        .pricing-grid { grid-template-columns: 1fr 1fr; }
    }
    
    .price {
        font-size: var(--text-3xl);
        font-weight: 700;
        color: var(--text);
    }
    
    .features-list {
        list-style: none;
        padding: 0;
        margin: 0;
        display: flex;
        flex-direction: column;
        gap: var(--space-2);
        color: var(--text-muted);
    }
    
    .border-primary {
        border-color: var(--primary);
        box-shadow: var(--shadow-lg);
    }
</style>
