---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Container from "../../../components/ui/Container.astro";
import Button from "../../../components/ui/Button.astro";

const focusAreas = [
  "Operational systems",
  "SaaS platforms",
  "Internal tools",
  "Integrations",
  "Reporting & BI",
  "Automation",
];

const solutions = [
  {
    title: "Operational software systems",
    text: "Custom systems for teams that need control over daily workflows, approvals, transactions, users and operational data.",
  },
  {
    title: "SaaS platforms",
    text: "Product-oriented web platforms designed with clear workflows, maintainable architecture and room to evolve.",
  },
  {
    title: "Internal business tools",
    text: "Focused tools for teams that need better visibility, fewer manual steps and a more reliable way to run operations.",
  },
  {
    title: "Integrations & APIs",
    text: "API-first integrations between business systems, payment flows, reporting tools and third-party services.",
  },
  {
    title: "Reporting & BI",
    text: "Dashboards, data models and reporting workflows that help teams understand what is happening in the business.",
  },
  {
    title: "Inventory & billing systems",
    text: "Operational modules for stock control, billing workflows, transaction tracking and business rule execution.",
  },
  {
    title: "Process automation",
    text: "Automation for repetitive processes where reliability, traceability and practical business value matter.",
  },
  {
    title: "Legacy modernization",
    text: "Incremental modernization for existing systems that need better maintainability, performance or integrations.",
  },
];

const operatingPrinciples = [
  "Start from the business operation, not from a template.",
  "Design workflows, data and integrations as one system.",
  "Build software that can be maintained, measured and improved.",
];
---

<BaseLayout
  title="Solutions"
  description="Software solutions for operational systems, SaaS platforms, internal tools, integrations, reporting, inventory, billing, automation and modernization."
  lang="en"
  isHeaderTransparent={false}
>
  <main class="solutions-page">
    <section class="solutions-hero" aria-labelledby="solutions-title">
      <Container>
        <div class="solutions-hero__grid">
          <div class="solutions-hero__content">
            <p class="page-kicker">Solutions</p>
            <h1 id="solutions-title">Software capabilities for real business operations</h1>
            <p>
              Quantix Software designs and builds reliable systems for companies that need operational control, clear data and scalable digital workflows.
            </p>
            <div class="page-actions">
              <Button href="/en/contact/" variant="primary" size="lg">Book a consultation</Button>
              <Button href="/en/products/" variant="secondary" size="lg">View products</Button>
            </div>
          </div>

          <aside class="solutions-panel" aria-label="Solution focus areas">
            <span>Focus areas</span>
            <ul>
              {focusAreas.map((item) => <li>{item}</li>)}
            </ul>
          </aside>
        </div>
      </Container>
    </section>

    <section class="positioning-band" aria-label="How Quantix approaches solutions">
      <Container>
        <div class="positioning-band__grid">
          {operatingPrinciples.map((item) => <p>{item}</p>)}
        </div>
      </Container>
    </section>

    <section class="solutions-section" aria-labelledby="capabilities-title">
      <Container>
        <div class="section-heading">
          <p class="page-kicker">Capabilities</p>
          <h2 id="capabilities-title">Built around operations, data and execution</h2>
          <p>
            The work is practical by design: structure the process, connect the systems, make the data usable and reduce manual effort where automation is valuable.
          </p>
        </div>

        <div class="solutions-grid">
          {solutions.map((solution) => (
            <article class="solution-card">
              <h3>{solution.title}</h3>
              <p>{solution.text}</p>
            </article>
          ))}
        </div>
      </Container>
    </section>

    <section class="solutions-section solutions-section--surface" aria-labelledby="scoping-title">
      <Container>
        <div class="cta-panel">
          <div>
            <p class="page-kicker">Project scoping</p>
            <h2 id="scoping-title">Need to define an operational system?</h2>
            <p>
              We can help clarify workflows, technical constraints, integration needs and a practical implementation path before development starts.
            </p>
          </div>
          <div class="page-actions">
            <Button href="/en/contact/" variant="primary" size="lg">Book a consultation</Button>
            <Button href="/en/work/" variant="secondary" size="lg">See experience areas</Button>
          </div>
        </div>
      </Container>
    </section>
  </main>
</BaseLayout>

<style>
  .solutions-page {
    background: var(--bg);
    color: var(--text);
  }

  .solutions-hero {
    padding: clamp(8rem, 13vw, 10rem) 0 clamp(4rem, 7vw, 5.5rem);
    border-bottom: 1px solid var(--border);
    background: linear-gradient(180deg, color-mix(in srgb, var(--primary-soft) 24%, var(--bg)) 0%, var(--bg) 76%);
  }

  .solutions-hero__grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(18rem, 0.44fr);
    gap: clamp(2rem, 5vw, 4.5rem);
    align-items: end;
  }

  .solutions-hero__content,
  .section-heading,
  .cta-panel > div {
    min-width: 0;
  }

  .page-kicker {
    margin: 0 0 var(--space-4);
    color: var(--primary);
    font-size: var(--text-sm);
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .solutions-hero h1 {
    max-width: 54rem;
    margin: 0;
    font-size: clamp(2.55rem, 6.4vw, 5rem);
    font-weight: 800;
    line-height: 1.02;
    letter-spacing: -0.024em;
    text-wrap: balance;
    overflow-wrap: break-word;
  }

  .solutions-hero__content > p:not(.page-kicker) {
    max-width: 45rem;
    margin: var(--space-6) 0 0;
    color: var(--text-muted);
    font-size: clamp(1.05rem, 2vw, 1.25rem);
    line-height: 1.7;
  }

  .page-actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    margin-top: var(--space-8);
  }

  .solutions-panel {
    padding: clamp(1.25rem, 3vw, 1.75rem);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    background: var(--surface);
    box-shadow: var(--shadow-sm);
  }

  .solutions-panel span {
    display: block;
    margin-bottom: var(--space-4);
    color: var(--text-muted);
    font-size: var(--text-sm);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .solutions-panel ul {
    display: grid;
    gap: var(--space-2);
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .solutions-panel li {
    padding: 0.7rem 0;
    border-top: 1px solid var(--border);
    font-weight: 800;
  }

  .positioning-band {
    padding: var(--space-5) 0;
    border-bottom: 1px solid var(--border);
    background: var(--surface);
  }

  .positioning-band__grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--space-4);
  }

  .positioning-band p {
    margin: 0;
    color: var(--text-muted);
    font-size: var(--text-sm);
    font-weight: 700;
    line-height: 1.55;
  }

  .solutions-section {
    padding: clamp(4rem, 7vw, 6rem) 0;
  }

  .solutions-section--surface {
    border-top: 1px solid var(--border);
    background: var(--surface-2);
  }

  .section-heading {
    max-width: 58rem;
    margin-bottom: var(--space-10);
  }

  .section-heading h2,
  .cta-panel h2 {
    margin: 0;
    font-size: clamp(2rem, 4.2vw, 3.2rem);
    font-weight: 800;
    line-height: 1.08;
    letter-spacing: -0.018em;
    text-wrap: balance;
  }

  .section-heading p:not(.page-kicker),
  .cta-panel p:not(.page-kicker) {
    max-width: 48rem;
    margin: var(--space-4) 0 0;
    color: var(--text-muted);
    font-size: var(--text-lg);
    line-height: 1.7;
  }

  .solutions-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: var(--space-4);
  }

  .solution-card {
    min-height: 100%;
    padding: clamp(1.2rem, 2.5vw, 1.6rem);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    background: var(--surface);
    box-shadow: var(--shadow-sm);
  }

  .solution-card h3 {
    margin: 0 0 var(--space-3);
    font-size: var(--text-lg);
    line-height: 1.25;
  }

  .solution-card p {
    margin: 0;
    color: var(--text-muted);
    font-size: var(--text-sm);
    line-height: 1.65;
  }

  .cta-panel {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-8);
    padding: clamp(2rem, 5vw, 3rem);
    border: 1px solid color-mix(in srgb, var(--primary) 10%, var(--border));
    border-radius: var(--radius-lg);
    background: linear-gradient(135deg, color-mix(in srgb, var(--surface) 94%, var(--primary-soft)), var(--surface));
  }

  .cta-panel > div {
    max-width: 46rem;
  }

  @media (max-width: 1080px) {
    .solutions-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 820px) {
    .solutions-hero__grid,
    .positioning-band__grid {
      grid-template-columns: 1fr;
    }

    .solutions-panel {
      max-width: none;
    }
  }

  @media (max-width: 640px) {
    .solutions-hero {
      padding-top: 7.5rem;
    }

    .solutions-hero h1 {
      max-width: 20rem;
      font-size: clamp(2rem, 9.6vw, 2.65rem);
      line-height: 1.08;
      letter-spacing: -0.014em;
      text-wrap: wrap;
    }

    .solutions-hero__content > p:not(.page-kicker),
    .section-heading p:not(.page-kicker),
    .cta-panel p:not(.page-kicker),
    .positioning-band p {
      max-width: 20rem;
    }

    .page-actions,
    .cta-panel {
      flex-direction: column;
      align-items: stretch;
    }

    .page-actions :global(.btn),
    .cta-panel :global(.btn) {
      width: 100%;
      justify-content: center;
    }

    .solutions-grid {
      grid-template-columns: 1fr;
    }

    .section-heading h2,
    .cta-panel h2 {
      max-width: 20rem;
      font-size: clamp(1.8rem, 8vw, 2.35rem);
    }
  }
</style>
